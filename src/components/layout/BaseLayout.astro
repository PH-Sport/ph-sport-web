---
import '@/styles/global.css';
import { ViewTransitions, fade } from 'astro:transitions';
import Header from './Header.astro';
import Footer from './Footer.astro';
import { useTranslations, getAlternateLangUrl, type Lang } from '@/i18n/utils';
import { SITE_URL } from '@/lib/constants';

interface Props {
  title: string;
  description: string;
  lang: Lang;
  canonical: string;
  ogImage?: string;
  hasHero?: boolean;
  noIndex?: boolean;
}

const { title, description, lang, canonical, ogImage, hasHero = false, noIndex = false } = Astro.props;
const t = useTranslations(lang);

const alternatePath = getAlternateLangUrl(Astro.url);
const esUrl = lang === 'es' ? canonical : `${SITE_URL}${alternatePath}`;
const enUrl = lang === 'en' ? canonical : `${SITE_URL}${alternatePath}`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="alternate" hreflang="es" href={esUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />

    {ogImage && <meta property="og:image" content={ogImage} />}

    <link rel="preload" href="/fonts/sohne/sohne-buch.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/sohne/sohne-halbfett.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/sohne/sohne-dreiviertelfett.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/sohne/sohne-extrafett.woff2" as="font" type="font/woff2" crossorigin />

    <ViewTransitions />
  </head>
  <body>
    <div class="bg-logo-parallax" aria-hidden="true" role="presentation">
      <div class="bg-logo-parallax__inner" data-parallax-inner>
        <img
          src="/logo-ph-3d.webp"
          srcset="/logo-ph-3d-sm.webp 820w, /logo-ph-3d.webp 1640w"
          sizes="min(92vw, 820px)"
          alt=""
          width="1640"
          height="1321"
          loading="lazy"
          decoding="async"
          fetchpriority="low"
          class="bg-logo-parallax__img"
        />
      </div>
    </div>
    <a href="#main-content" class="skip-link">{t('a11y.skip')}</a>
    <Header />
    <main
      id="main-content"
      class:list={[!hasHero && 'main--padded']}
      transition:name="page-main"
      transition:animate={fade({ duration: '0.4s' })}
    >
      <slot />
    </main>
    <Footer />

    <script>
      const HEADER_SCROLL_THRESHOLD = 16;
      const SCROLL_HIDE_MIN_Y = 64;
      const SCROLL_DIRECTION_DELTA = 6;
      const PARALLAX_FACTOR = 0.1;

      let lastScrollY = 0;

      function prefersReducedMotion(): boolean {
        return window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      }

      function isMobileMenuOpen(): boolean {
        return document.querySelector('[data-mobile-menu]')?.classList.contains('is-open') ?? false;
      }

      function updateScrollEffects() {
        const header = document.querySelector('[data-header]');
        const parallaxInner = document.querySelector('[data-parallax-inner]');
        const y = window.scrollY;

        header?.classList.toggle('header--solid', y > HEADER_SCROLL_THRESHOLD);
        if (parallaxInner) {
          (parallaxInner as HTMLElement).style.transform =
            `translate3d(0, ${y * PARALLAX_FACTOR}px, 0)`;
        }

        if (!header) {
          return;
        }

        if (prefersReducedMotion()) {
          header.classList.remove('header--scroll-hidden');
          lastScrollY = y;
          return;
        }

        if (
          document.documentElement.classList.contains('ph-logo-reveal-active') ||
          isMobileMenuOpen()
        ) {
          header.classList.remove('header--scroll-hidden');
          lastScrollY = y;
          return;
        }

        if (y < SCROLL_HIDE_MIN_Y) {
          header.classList.remove('header--scroll-hidden');
          lastScrollY = y;
          return;
        }

        const delta = y - lastScrollY;
        if (Math.abs(delta) >= SCROLL_DIRECTION_DELTA) {
          if (delta > 0) {
            header.classList.add('header--scroll-hidden');
          } else {
            header.classList.remove('header--scroll-hidden');
          }
        }
        lastScrollY = y;
      }

      function onPageLoad() {
        lastScrollY = window.scrollY;
        document.querySelector('[data-header]')?.classList.remove('header--scroll-hidden');
        updateScrollEffects();
      }

      document.addEventListener('astro:page-load', onPageLoad);
      document.addEventListener('scroll', updateScrollEffects, { passive: true });
    </script>
  </body>
</html>

<style is:global>
  /* Fondo logo 3D con parallax (JS mueve __inner más lento que el scroll) */
  .bg-logo-parallax {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .bg-logo-parallax__inner {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding-right: 10%;
    opacity: 0.22;
    will-change: transform;
  }

  .bg-logo-parallax__img {
    width: min(92vw, 820px);
    height: auto;
    pointer-events: none;
    user-select: none;
  }

  #main-content {
    position: relative;
    z-index: 1;
  }

  .main--padded {
    /* 5rem reserva la zona del header; +0.875rem el margen superior de la cápsula flotante */
    padding-top: calc(5rem + 0.875rem);
  }

  /* LogoReveal vive dentro de main (z-index 1); el header fijo quedaría encima del overlay.
     LogoReveal añade html.ph-logo-reveal-active mientras corre la animación.
     Mientras dura, el header queda oculto y sin pointer-events: evita que tape el overlay
     y es intencional (no se puede abrir el menú u otras acciones del chrome hasta terminar). */
  html.ph-logo-reveal-active [data-header] {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  [data-header] {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: transparent;
    border: none;
    pointer-events: none;
    transition: none;
  }

  /* Hit target: solo la cápsula recibe eventos */
  [data-header] .header-shell {
    pointer-events: auto;
  }

  [data-header].header--scroll-hidden {
    pointer-events: none;
  }

  [data-header] .header-shell {
    background-color: transparent;
    border: 1px solid transparent;
    backdrop-filter: blur(0);
    -webkit-backdrop-filter: blur(0);
    box-shadow: none;
  }

  [data-header].header--solid .header-shell {
    background-color: rgba(13, 15, 18, 0.88);
    border-color: var(--ph-glass-border);
    backdrop-filter: blur(var(--ph-glass-blur));
    -webkit-backdrop-filter: blur(var(--ph-glass-blur));
    box-shadow: var(--ph-glass-highlight);
  }

  [data-header].header--scroll-hidden .header-shell {
    transform: translateY(calc(-100% - 0.875rem));
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    [data-header].header--scroll-hidden .header-shell {
      transform: none;
      pointer-events: auto;
    }
  }

  /* Página laboratorio logo 3D: ocultar parallax del logo estático de fondo */
  html:has([data-ph-logo-lab]) .bg-logo-parallax {
    opacity: 0;
    visibility: hidden;
  }
</style>
