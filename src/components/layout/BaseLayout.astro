---
import '@/styles/global.css';
import { ClientRouter, fade } from 'astro:transitions';
import Header from './Header.astro';
import Footer from './Footer.astro';
import { useTranslations, getAlternateLangUrl, type Lang } from '@/i18n/utils';
import { SITE_URL } from '@/lib/constants';
import { SOCIAL_LINKS, isSocialPlaceholder } from '@/lib/social';

interface Props {
  title: string;
  description: string;
  lang: Lang;
  canonical: string;
  ogImage?: string;
  hasHero?: boolean;
  noIndex?: boolean;
  /**
   * Imagen LCP a precargar. Si la imagen tiene variantes responsive,
   * pasa { mobile, desktop } y se emiten dos preloads media-aware
   * para evitar descargar las dos.
   */
  preloadImage?: string | { mobile: string; desktop: string; mobileMaxWidth?: number };
}

const { title, description, lang, canonical, ogImage, hasHero = false, noIndex = false, preloadImage } = Astro.props;
const preloadIsResponsive = typeof preloadImage === 'object' && preloadImage !== null;
const preloadMobile = preloadIsResponsive ? preloadImage.mobile : null;
const preloadDesktop = preloadIsResponsive ? preloadImage.desktop : null;
const preloadBreakpoint = preloadIsResponsive ? (preloadImage.mobileMaxWidth ?? 720) : 720;
const preloadSingle = typeof preloadImage === 'string' ? preloadImage : null;
const t = useTranslations(lang);

const alternatePath = getAlternateLangUrl(Astro.url);
const esUrl = lang === 'es' ? canonical : `${SITE_URL}${alternatePath}`;
const enUrl = lang === 'en' ? canonical : `${SITE_URL}${alternatePath}`;

// OG image: el override (`ogImage`) puede llegar relativo o absoluto.
// Sin override, fallback al asset por defecto. La spec OG exige URL absoluta.
const ogImageRaw = ogImage ?? '/og-image.jpg';
const ogImageUrl = ogImageRaw.startsWith('http') ? ogImageRaw : `${SITE_URL}${ogImageRaw}`;

// WebSite: esquema que Google usa específicamente para el "site name" en SERP
// (el nombre junto al logo y la URL). Sin esto, Google lo deriva del dominio en minúsculas.
const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'PHSPORT',
  url: SITE_URL,
};

// SportsOrganization: identidad de marca para que Google muestre "PHSPORT" en
// SERP en lugar de derivar el nombre del dominio en minúsculas. Bloque global;
// la description sigue el idioma de la página actual.
const organizationJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SportsOrganization',
  name: 'PHSPORT',
  alternateName: 'PHSPORT Management',
  url: SITE_URL,
  logo: `${SITE_URL}/logo.svg`,
  description: t('site.description'),
  sameAs: SOCIAL_LINKS.filter((s) => !isSocialPlaceholder(s.href)).map((s) => s.href),
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer support',
    email: 'info@phsport.es',
    availableLanguage: ['Spanish', 'English'],
  },
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    {/* Iconos: SVG primario + PNG fallback + apple-touch (iOS home screen) + mask-icon (Safari pinned tab). */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="mask-icon" href="/mask-icon.svg" color="#D6B25E" />
    <meta name="theme-color" content="#0d0f12" />

    {/* iOS: si el usuario añade phsport.es a Home Screen, abre standalone (sin chrome de Safari)
        con status bar translúcido sobre el hero negro. Title corto bajo el icono. */}
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="PHSPORT" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="alternate" hreflang="es" href={esUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    {/* x-default: usuarios fuera de es/en (otras regiones/idiomas) ven la versión española. */}
    <link rel="alternate" hreflang="x-default" href={esUrl} />

    <script type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(organizationJsonLd)} />

    {/* Open Graph: tarjetas ricas en WhatsApp, iMessage, LinkedIn, Slack, Discord, FB. */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="PHSPORT" />
    <meta property="og:locale" content={lang === 'es' ? 'es_ES' : 'en_US'} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    {/* Twitter / X: usa su propio namespace; `summary_large_image` muestra hero a ancho completo. */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="preload" href="/fonts/sohne/sohne-buch.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/sohne/sohne-halbfett.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/sohne/sohne-dreiviertelfett.woff2" as="font" type="font/woff2" crossorigin />

    {preloadSingle && <link rel="preload" as="image" href={preloadSingle} />}
    {preloadIsResponsive && (
      <>
        <link rel="preload" as="image" href={preloadMobile} media={`(max-width: ${preloadBreakpoint}px)`} />
        <link rel="preload" as="image" href={preloadDesktop} media={`(min-width: ${preloadBreakpoint + 1}px)`} />
      </>
    )}

    <ClientRouter />
  </head>
  <body>
    <a href="#main-content" class="skip-link">{t('a11y.skip')}</a>
    <Header />
    <main
      id="main-content"
      class:list={[!hasHero && 'main--padded']}
      transition:name="page-main"
      transition:animate={fade({ duration: '0.15s' })}
    >
      <slot />
    </main>
    <Footer />

    <script>
      const HEADER_SCROLL_THRESHOLD = 16;
      const SCROLL_HIDE_MIN_Y = 64;
      const SCROLL_DIRECTION_DELTA = 6;

      let lastScrollY = 0;
      let scrollFrameScheduled = false;

      function prefersReducedMotion(): boolean {
        return window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      }

      function isMobileMenuOpen(): boolean {
        return document.querySelector('[data-mobile-menu]')?.classList.contains('is-open') ?? false;
      }

      // Lecturas primero, escrituras después: evita que un classList.toggle
      // invalide layout y forme el patrón read-write-read-write que causaba
      // forced reflow (19-48 ms por scroll en el audit perf).
      function updateScrollEffects() {
        const header = document.querySelector('[data-header]');
        if (!header) return;

        // PHASE 1 — reads
        const y = window.scrollY;
        const reducedMotion = prefersReducedMotion();
        const revealActive = document.documentElement.classList.contains('ph-logo-reveal-active');
        const menuOpen = isMobileMenuOpen();
        const wasHidden = header.classList.contains('header--scroll-hidden');
        const delta = y - lastScrollY;

        // PHASE 2 — compute (sin tocar DOM)
        const shouldBeSolid = y > HEADER_SCROLL_THRESHOLD;
        let shouldHide = wasHidden;

        if (reducedMotion || revealActive || menuOpen || y < SCROLL_HIDE_MIN_Y) {
          shouldHide = false;
        } else if (Math.abs(delta) >= SCROLL_DIRECTION_DELTA) {
          shouldHide = delta > 0;
        }

        // PHASE 3 — writes
        header.classList.toggle('header--solid', shouldBeSolid);
        header.classList.toggle('header--scroll-hidden', shouldHide);

        lastScrollY = y;
      }

      // rAF-throttle: coalesce múltiples scroll events en un único update por frame.
      function onScroll() {
        if (scrollFrameScheduled) return;
        scrollFrameScheduled = true;
        requestAnimationFrame(() => {
          updateScrollEffects();
          scrollFrameScheduled = false;
        });
      }

      function onPageLoad() {
        lastScrollY = window.scrollY;
        document.querySelector('[data-header]')?.classList.remove('header--scroll-hidden');
        updateScrollEffects();
      }

      document.addEventListener('astro:page-load', onPageLoad);
      document.addEventListener('scroll', onScroll, { passive: true });
    </script>

  </body>
</html>

<style is:global>
  .main--padded {
    /* 5rem reserva la zona del header; +0.875rem el margen superior de la cápsula flotante */
    padding-top: calc(5rem + 0.875rem);
  }

  /* LogoReveal vive dentro de main (z-index 1); el header fijo quedaría encima del overlay.
     LogoReveal añade html.ph-logo-reveal-active mientras corre la animación.
     Mientras dura, el header queda oculto y sin pointer-events: evita que tape el overlay
     y es intencional (no se puede abrir el menú u otras acciones del chrome hasta terminar). */
  html.ph-logo-reveal-active [data-header] {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  [data-header] {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: transparent;
    border: none;
    pointer-events: none;
    transition: none;
  }

  /* En mobile el header siempre encima del overlay (z-index 100) sin depender de .is-open,
     así evitamos el salto de z-index en el momento en que se elimina la clase al cerrar. */
  @media (max-width: 767px) {
    [data-header] {
      z-index: 110;
    }
  }

  /* Hit target: solo la cápsula recibe eventos */
  [data-header] .header-shell {
    pointer-events: auto;
  }

  [data-header].header--scroll-hidden {
    pointer-events: none;
  }

  [data-header] .header-shell {
    background-color: transparent;
    border: 1px solid transparent;
    /* Sin backdrop-filter cuando el header es transparente: blur(0) seguía
       asignando un render pass GPU innecesario. Solo se aplica cuando
       header--solid lo necesita de verdad. */
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    box-shadow: none;
  }

  [data-header].header--solid .header-shell {
    background-color: rgba(13, 15, 18, 0.88);
    border-color: var(--ph-glass-border);
    backdrop-filter: var(--ph-glass-backdrop);
    -webkit-backdrop-filter: var(--ph-glass-backdrop);
    box-shadow: var(--ph-glass-highlight);
  }

  [data-header].header--scroll-hidden .header-shell {
    transform: translateY(calc(-100% - 0.875rem));
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    [data-header].header--scroll-hidden .header-shell {
      transform: none;
      pointer-events: auto;
    }
  }

  /* Menú móvil abierto: la cápsula del header se funde con el overlay */
  @media (max-width: 767px) {
    html:has(#mobile-menu.is-open) [data-header] .header-shell {
      background-color: transparent;
      border-color: transparent;
      backdrop-filter: blur(0);
      -webkit-backdrop-filter: blur(0);
      box-shadow: none;
    }
  }

</style>
