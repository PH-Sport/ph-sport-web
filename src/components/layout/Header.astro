---
import { useTranslations, getLangFromUrl, getAlternateLangUrl } from '@/i18n/utils';
import { NAV_ITEMS } from '@/lib/navigation';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const alternateLangUrl = getAlternateLangUrl(Astro.url);
const isEn = lang === 'en';
const currentPath = Astro.url.pathname === '/' ? '/' : Astro.url.pathname.replace(/\/$/, '');

const nav = NAV_ITEMS.map((item) => ({
  href: item.href[lang],
  label: t(item.labelKey),
}));

const isActive = (href: string): boolean => {
  const normalizedHref = href === '/' ? '/' : href.replace(/\/$/, '');
  return normalizedHref === currentPath;
};
---

<header data-header transition:persist>
  <div class="header-shell">
    <div class="header-inner">
      <a href={isEn ? '/en/' : '/'} class="header-logo" aria-label={t('a11y.logo')}>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 259.8 206.1" fill="currentColor" aria-hidden="true">
          <polygon points="0 206.1 58.2 206.1 57.9 145.5 158.1 45.4 112.7 0 0 0 0 52.6 76.9 52.6 0 128.7" />
          <polygon points="122.6 206.1 200.1 206.1 152.2 157.8 173 137.1 182.4 146.4 259.8 146.4 169.6 55.6 130.5 94.2 131.8 95.6 141.1 105.4 120.3 125.8 109.8 115.4 70.8 153.9" />
        </svg>
      </a>

      <nav class="header-nav hidden md:block" aria-label={t('nav.aria.main')}>
        <div class="header-nav-list-wrap">
          <span class="nav-indicator" aria-hidden="true" data-nav-indicator></span>
          <ul class="header-nav-list">
            {nav.map((item) => (
              <li>
                <a
                  href={item.href}
                  class:list={['nav-link', isActive(item.href) && 'is-active']}
                >
                  {item.label}
                </a>
              </li>
            ))}
            <li>
              <a
                href={alternateLangUrl}
                class="lang-switch"
                aria-label={t('nav.lang.switch')}
              >
                <img
                  src={isEn ? '/icons/flag-es.svg' : '/icons/flag-uk.svg'}
                  alt=""
                  width="20"
                  height="15"
                  class="lang-flag"
                />
                <span class="lang-label">{t('nav.lang.label')}</span>
              </a>
            </li>
          </ul>
        </div>
      </nav>

      <button
        type="button"
        class="menu-toggle menu-toggle--hamburger md:hidden"
        data-menu-toggle
        data-label-open={t('a11y.menu.open')}
        data-label-close={t('a11y.menu.close')}
        aria-controls="mobile-menu"
        aria-expanded="false"
        aria-label={t('a11y.menu.open')}
      >
        <span class="menu-toggle__inner" aria-hidden="true">
          <span class="menu-toggle__bar"></span>
          <span class="menu-toggle__bar"></span>
          <span class="menu-toggle__bar"></span>
        </span>
      </button>
    </div>
  </div>
</header>

<!-- Overlay fuera de [data-header]: evita que backdrop-filter del header ancle position:fixed al rectángulo de la barra. -->
<div id="mobile-menu" class="mobile-menu" data-mobile-menu aria-hidden="true">
  <div
    class="mobile-menu-backdrop"
    data-mobile-menu-dismiss
    aria-hidden="true"
  ></div>
  <div class="mobile-menu-inner">
    <nav aria-label={t('nav.aria.mobile')}>
      <ul class="mobile-nav-list">
        {nav.map((item, i) => (
          <li>
            <a
              href={item.href}
              data-mobile-link
              class:list={[
                'mobile-link',
                isActive(item.href) && 'mobile-link--active',
              ]}
            >
              <span class="mobile-link-num">{String(i + 1).padStart(2, '0')}</span>
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="ph-divider"></div>

    <a
      href={alternateLangUrl}
      data-mobile-link
      class="lang-switch lang-switch--mobile"
      aria-label={t('nav.lang.switch')}
    >
      <img
        src={isEn ? '/icons/flag-es.svg' : '/icons/flag-uk.svg'}
        alt=""
        width="24"
        height="18"
        class="lang-flag"
      />
      <span class="lang-label">{t('nav.lang.labelMobile')}</span>
    </a>
  </div>
</div>

<style>
  /* ── Cápsula flotante (glass / sólido / hide-on-scroll en BaseLayout global) ── */
  .header-shell {
    width: calc(100% - 2 * var(--ph-section-px));
    margin-inline: auto;
    margin-top: 0.875rem;
    border-radius: var(--radius-md);
    transition:
      transform var(--ph-duration) var(--ease-ph),
      background-color var(--ph-duration) var(--ease-ph),
      border-color var(--ph-duration) var(--ease-ph),
      backdrop-filter var(--ph-duration) var(--ease-ph),
      -webkit-backdrop-filter var(--ph-duration) var(--ease-ph),
      box-shadow var(--ph-duration) var(--ease-ph);
  }

  @media (max-width: 767px) {
    .header-shell {
      margin-top: 0.5rem;
    }
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-inline: var(--ph-section-px);
    padding-block: 1.25rem;
  }

  @media (max-width: 767px) {
    .header-inner {
      padding-block: 0.625rem;
    }
  }

  /* ── Logo ── */
  .header-logo {
    color: var(--color-ph-gold);
    transition: color var(--ph-duration) var(--ease-ph);
  }

  .header-logo svg {
    height: 1.75rem;
    width: auto;
  }

  @media (max-width: 767px) {
    .header-logo svg {
      height: 1.5rem;
    }
  }

  .header-logo:hover {
    color: var(--color-ph-gold-muted);
  }

  /* ── Desktop nav ── */
  .header-nav {
    display: none;
  }

  @media (min-width: 768px) {
    .header-nav {
      display: block;
    }
  }

  .header-nav-list {
    display: flex;
    align-items: center;
    gap: 2rem;
    list-style: none;
  }

  .nav-link {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--color-ph-white-60);
    position: relative;
    padding-block: 0.25rem;
    transition: color var(--ph-duration) var(--ease-ph);
  }

  .nav-link:hover,
  .nav-link.is-active {
    color: var(--color-ph-white);
  }

  .header-nav-list-wrap {
    position: relative;
  }

  .nav-indicator {
    position: absolute;
    bottom: -0.375rem;
    left: 0;
    width: 0;
    height: 1.5px;
    background: var(--color-ph-gold);
    border-radius: 1px;
    pointer-events: none;
  }

  .nav-indicator.is-animated {
    transition:
      left 0.4s cubic-bezier(0.34, 1.2, 0.64, 1),
      width 0.4s cubic-bezier(0.34, 1.2, 0.64, 1);
  }

  /* ── Language switch ── */
  .lang-switch {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.3rem 0.625rem;
    border: 1px solid var(--color-ph-white-10);
    border-radius: var(--radius-sm);
    transition:
      border-color var(--ph-duration) var(--ease-ph),
      background-color var(--ph-duration) var(--ease-ph);
  }

  .lang-switch:hover {
    border-color: var(--color-ph-white-20);
    background-color: var(--color-ph-white-10);
  }

  .lang-flag {
    display: block;
    height: 0.875rem;
    width: auto;
    border-radius: 1px;
  }

  .lang-label {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--color-ph-white-60);
  }

  .lang-switch--mobile {
    width: fit-content;
    padding: 0.5rem 0.875rem;
  }

  .lang-switch--mobile .lang-flag {
    height: 1.125rem;
  }

  .lang-switch--mobile .lang-label {
    font-size: 0.875rem;
  }

  /* ── Mobile toggle: hamburguesa asimétrica → X (sin caja en móvil) ── */
  .menu-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.75rem;
    min-height: 2.75rem;
    width: 2.75rem;
    height: 2.75rem;
    border: 1px solid var(--color-ph-white-10);
    border-radius: var(--radius-sm);
    color: var(--color-ph-white);
    background: transparent;
    cursor: pointer;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
    transition:
      border-color var(--ph-duration) var(--ease-ph),
      color var(--ph-duration) var(--ease-ph),
      background-color var(--ph-duration) var(--ease-ph);
  }

  @media (max-width: 767px) {
    .menu-toggle--hamburger {
      width: auto;
      height: auto;
      min-width: 2.75rem;
      min-height: 2.75rem;
      padding: 0.5rem;
      border: none;
      border-radius: 0;
      background: transparent;
    }

    .menu-toggle--hamburger:hover,
    .menu-toggle--hamburger:active {
      background: transparent;
    }

    .menu-toggle--hamburger:focus {
      outline: none;
    }

    .menu-toggle--hamburger:focus-visible {
      outline: 2px solid var(--color-ph-gold-muted);
      outline-offset: 4px;
      border-radius: var(--radius-sm);
    }
  }

  @media (min-width: 768px) {
    .menu-toggle {
      display: none;
    }
  }

  @media (hover: hover) and (min-width: 768px) {
    .menu-toggle:hover {
      border-color: var(--color-ph-gold);
      color: var(--color-ph-gold);
      background-color: rgba(214, 178, 94, 0.05);
    }
  }

  @media (hover: hover) {
    .menu-toggle--hamburger:hover {
      color: var(--color-ph-gold);
    }
  }

  .menu-toggle:active {
    border-color: var(--color-ph-gold-muted);
    color: var(--color-ph-gold-muted);
    background-color: rgba(214, 178, 94, 0.08);
    transition-duration: 120ms;
  }

  @media (max-width: 767px) {
    .menu-toggle--hamburger:active {
      color: var(--color-ph-gold-muted);
      background: transparent;
    }
  }

  .menu-toggle__inner {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    width: 1.375rem;
    height: 0.875rem;
    flex-shrink: 0;
  }

  .menu-toggle__bar {
    display: block;
    height: 2px;
    border-radius: 1px;
    background: currentColor;
    align-self: flex-start;
    transform-origin: center;
    transition:
      transform 0.32s var(--ease-ph),
      opacity 0.22s var(--ease-ph),
      width 0.22s var(--ease-ph);
  }

  .menu-toggle__bar:nth-child(1) {
    width: 100%;
  }

  /* Barra central: sobresale a la izquierda y un poco más larga hacia la derecha que antes */
  .menu-toggle__bar:nth-child(2) {
    width: 78%;
    margin-left: -0.1875rem;
  }

  .menu-toggle__bar:nth-child(3) {
    width: 85%;
  }

  .menu-toggle--hamburger[aria-expanded='true'] .menu-toggle__bar:nth-child(1) {
    width: 100%;
    transform: translateY(6px) rotate(45deg);
  }

  .menu-toggle--hamburger[aria-expanded='true'] .menu-toggle__bar:nth-child(2) {
    opacity: 0;
  }

  .menu-toggle--hamburger[aria-expanded='true'] .menu-toggle__bar:nth-child(3) {
    width: 100%;
    transform: translateY(-6px) rotate(-45deg);
  }

  @media (prefers-reduced-motion: reduce) {
    .menu-toggle__bar {
      transition: none;
    }
  }

  /* ── Mobile menu: base opaca + glass; overlay con opacity (visibility retardada al cerrar para permitir transición) ── */
  .mobile-menu {
    --menu-anim-duration: 420ms;
    --menu-nav-stagger-step: 0.04s;
    --menu-nav-li-duration: 0.38s;
    position: fixed;
    inset: 0;
    z-index: 100;
    isolation: isolate;
    min-height: 100vh;
    min-height: 100dvh;
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.06) 0%, rgba(255, 255, 255, 0) 32%),
      rgba(255, 255, 255, 0.03),
      var(--color-ph-black);
    backdrop-filter: var(--ph-glass-backdrop);
    -webkit-backdrop-filter: var(--ph-glass-backdrop);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.08),
      0 24px 80px rgba(0, 0, 0, 0.45);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition:
      opacity 280ms var(--ease-ph),
      visibility 0s linear 280ms;
  }

  @supports not (backdrop-filter: blur(1px)) {
    .mobile-menu {
      background: var(--color-ph-black);
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
    }
  }

  .mobile-menu.is-open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transition:
      opacity var(--menu-anim-duration) var(--ease-ph),
      visibility 0s linear 0s;
  }

  /* Capa detrás del contenido: recibe toques en el “vacío” (.mobile-menu-inner tiene pointer-events: none). */
  .mobile-menu-backdrop {
    position: absolute;
    inset: 0;
    z-index: 0;
    cursor: pointer;
  }

  .mobile-menu-inner {
    --menu-inner-duration: calc(var(--menu-anim-duration) + 40ms);
    position: relative;
    z-index: 1;
    pointer-events: none;
    max-width: none;
    width: 100%;
    min-height: 100vh;
    min-height: 100dvh;
    margin-inline: auto;
    padding-inline: var(--ph-section-px);
    /* padding-top explícito para poder interpolarlo al cerrar (evita el salto al quitar .is-open) */
    padding-top: 1.25rem;
    padding-bottom: 3rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    opacity: 0;
    transform: translateY(1rem);
    transition:
      opacity var(--menu-inner-duration) var(--ease-ph),
      transform var(--menu-inner-duration) var(--ease-ph),
      padding-top var(--menu-inner-duration) var(--ease-ph);
  }

  .mobile-menu.is-open .mobile-menu-inner {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.04s;
    /* Contenido por debajo del header fijo (medido en JS → --mobile-menu-chrome-offset) */
    padding-top: calc(var(--mobile-menu-chrome-offset, 0px) + 0.75rem);
  }

  .mobile-menu-inner nav,
  .mobile-menu-inner .lang-switch--mobile {
    pointer-events: auto;
  }

  /* Enlaces: entrada escalonada al abrir; cierre escalonado inverso con .mobile-menu--closing */
  .mobile-menu .mobile-nav-list li {
    opacity: 0;
    transform: translateX(-0.75rem);
    transition:
      opacity var(--menu-nav-li-duration) var(--ease-ph),
      transform var(--menu-nav-li-duration) var(--ease-ph);
  }

  .mobile-menu.is-open .mobile-nav-list li {
    opacity: 1;
    transform: translateX(0);
  }

  .mobile-menu.is-open .mobile-nav-list li:nth-child(1) {
    transition-delay: 0.1s;
  }
  .mobile-menu.is-open .mobile-nav-list li:nth-child(2) {
    transition-delay: 0.15s;
  }
  .mobile-menu.is-open .mobile-nav-list li:nth-child(3) {
    transition-delay: 0.2s;
  }
  .mobile-menu.is-open .mobile-nav-list li:nth-child(4) {
    transition-delay: 0.25s;
  }
  .mobile-menu.is-open .mobile-nav-list li:nth-child(5) {
    transition-delay: 0.3s;
  }

  @media (max-width: 767px) {
    .mobile-menu.is-open .mobile-nav-list li:nth-child(1) {
      transition-delay: 0.04s;
    }
    .mobile-menu.is-open .mobile-nav-list li:nth-child(2) {
      transition-delay: 0.08s;
    }
    .mobile-menu.is-open .mobile-nav-list li:nth-child(3) {
      transition-delay: 0.12s;
    }
    .mobile-menu.is-open .mobile-nav-list li:nth-child(4) {
      transition-delay: 0.16s;
    }
    .mobile-menu.is-open .mobile-nav-list li:nth-child(5) {
      transition-delay: 0.2s;
    }
  }

  /* Cierre inverso (5→1), mantiene .is-open hasta que JS quite ambas clases */
  .mobile-menu.is-open.mobile-menu--closing .mobile-nav-list li {
    opacity: 0;
    transform: translateX(-0.75rem);
    transition-duration: 0.2s;
  }

  .mobile-menu.is-open.mobile-menu--closing .mobile-nav-list li:nth-child(5) {
    transition-delay: 0s;
  }

  .mobile-menu.is-open.mobile-menu--closing .mobile-nav-list li:nth-child(4) {
    transition-delay: var(--menu-nav-stagger-step);
  }

  .mobile-menu.is-open.mobile-menu--closing .mobile-nav-list li:nth-child(3) {
    transition-delay: calc(2 * var(--menu-nav-stagger-step));
  }

  .mobile-menu.is-open.mobile-menu--closing .mobile-nav-list li:nth-child(2) {
    transition-delay: calc(3 * var(--menu-nav-stagger-step));
  }

  .mobile-menu.is-open.mobile-menu--closing .mobile-nav-list li:nth-child(1) {
    transition-delay: calc(4 * var(--menu-nav-stagger-step));
  }

  .mobile-menu.is-open.mobile-menu--closing .ph-divider {
    opacity: 0;
    transform: translateY(0.35rem);
    transition-delay: 0.14s;
    transition-duration: 0.2s;
  }

  .mobile-menu.is-open.mobile-menu--closing .lang-switch--mobile {
    opacity: 0;
    transform: translateY(0.35rem);
    transition-delay: 0.18s;
    transition-duration: 0.2s;
  }

  .mobile-menu.mobile-menu--closing .mobile-menu-backdrop {
    pointer-events: none;
  }

  .mobile-menu.mobile-menu--closing .mobile-menu-inner nav,
  .mobile-menu.mobile-menu--closing .mobile-menu-inner .lang-switch--mobile {
    pointer-events: none;
  }

  .mobile-menu .ph-divider {
    opacity: 0;
    transform: translateY(0.35rem);
    transition:
      opacity 0.35s var(--ease-ph),
      transform 0.35s var(--ease-ph);
  }

  .mobile-menu.is-open .ph-divider {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.34s;
  }

  .mobile-menu .lang-switch--mobile {
    opacity: 0;
    transform: translateY(0.35rem);
    transition:
      opacity 0.38s var(--ease-ph),
      transform 0.38s var(--ease-ph);
  }

  .mobile-menu.is-open .lang-switch--mobile {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.38s;
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-menu {
      --menu-anim-duration: 1ms;
      transition: none;
    }

    .mobile-menu.is-open {
      transition: none;
    }

    .mobile-menu-inner,
    .mobile-menu.is-open .mobile-menu-inner,
    .mobile-menu .mobile-nav-list li,
    .mobile-menu.is-open .mobile-nav-list li,
    .mobile-menu.is-open.mobile-menu--closing .mobile-nav-list li,
    .mobile-menu .ph-divider,
    .mobile-menu.is-open .ph-divider,
    .mobile-menu.is-open.mobile-menu--closing .ph-divider,
    .mobile-menu .lang-switch--mobile,
    .mobile-menu.is-open .lang-switch--mobile,
    .mobile-menu.is-open.mobile-menu--closing .lang-switch--mobile {
      opacity: 1;
      transform: none;
      transition: none;
      transition-delay: 0s !important;
    }
  }

  .mobile-nav-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    list-style: none;
    padding-top: 0.25rem;
  }

  /* ── Mobile nav links ── */
  .mobile-link {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-ph-white-60);
    transition: color var(--ph-duration) var(--ease-ph);
  }

  .mobile-link:hover,
  .mobile-link--active {
    color: var(--color-ph-white);
  }

  .mobile-link:active {
    color: var(--color-ph-white);
    opacity: 0.88;
    transition-duration: 120ms;
  }

  .lang-switch--mobile:active {
    border-color: var(--color-ph-white-20);
    background-color: var(--color-ph-white-10);
    transition-duration: 120ms;
  }

  .mobile-link-num {
    font-size: 0.6875rem;
    font-weight: 400;
    color: var(--color-ph-gold);
    letter-spacing: 0;
    min-width: 1.5rem;
  }

  @media (min-width: 768px) {
    .mobile-menu {
      display: none;
    }
  }
</style>

<script>
  // ── Nav indicator deslizante ──────────────────────────────────────────────
  const wrap = document.querySelector<HTMLElement>('.header-nav-list-wrap');
  const indicator = document.querySelector<HTMLElement>('[data-nav-indicator]');
  const desktopLinks = Array.from(
    document.querySelectorAll<HTMLAnchorElement>('.header-nav .nav-link'),
  );

  let indicatorReady = false;

  function setIndicatorToLink(link: HTMLElement) {
    if (!wrap || !indicator || !link) return;
    const wrapRect = wrap.getBoundingClientRect();
    const linkRect = link.getBoundingClientRect();
    indicator.style.left = `${linkRect.left - wrapRect.left}px`;
    indicator.style.width = `${linkRect.width}px`;
  }

  // ── Rutas derivadas de la fuente central (src/lib/navigation.ts) ────────
  import { NAV_ITEMS } from '@/lib/navigation';
  import es from '@/i18n/es';
  import en from '@/i18n/en';

  const translations = { es, en } as const;

  const NAV_HREFS = {
    es: NAV_ITEMS.map((i) => i.href.es),
    en: NAV_ITEMS.map((i) => i.href.en),
  };

  const NAV_LABELS = {
    es: NAV_ITEMS.map((i) => translations.es[i.labelKey]),
    en: NAV_ITEMS.map((i) => translations.en[i.labelKey]),
  };

  const STATIC_ROUTE_PAIRS = NAV_ITEMS.map((i) => i.href);

  function norm(p: string): string {
    return p === '/' ? '/' : p.replace(/\/+$/, '');
  }

  function getAlternateUrl(pathname: string): string {
    const p = norm(pathname);
    for (const r of STATIC_ROUTE_PAIRS) {
      if (p === norm(r.es)) return r.en;
      if (p === norm(r.en)) return r.es;
    }
    return '/';
  }

  function syncHeaderToCurrentPage() {
    const isEn = window.location.pathname.startsWith('/en');
    const lang = isEn ? 'en' : 'es';
    const currentPath = norm(window.location.pathname);

    // Actualizar hrefs, labels e is-active de los enlaces de escritorio
    desktopLinks.forEach((link, i) => {
      const href = NAV_HREFS[lang][i] ?? link.href;
      link.href = href;
      link.textContent = NAV_LABELS[lang][i] ?? link.textContent;
      link.classList.toggle('is-active', norm(href) === currentPath);
    });

    // Actualizar hrefs, labels e is-active del menú móvil
    document
      .querySelectorAll<HTMLAnchorElement>('.mobile-nav-list .mobile-link')
      .forEach((link, i) => {
        const href = NAV_HREFS[lang][i];
        const label = NAV_LABELS[lang][i];
        if (href) link.href = href;
        link.classList.toggle('mobile-link--active', norm(href ?? '') === currentPath);
        // Preservar el span numerador y actualizar solo el texto del label
        if (label) {
          const numSpan = link.querySelector('.mobile-link-num');
          link.textContent = label;
          if (numSpan) link.prepend(numSpan);
        }
      });

    // Logo
    const logo = document.querySelector<HTMLAnchorElement>('a.header-logo');
    if (logo) logo.href = isEn ? '/en/' : '/';

    // Href del selector de idioma
    const altUrl = getAlternateUrl(window.location.pathname);
    document.querySelectorAll<HTMLAnchorElement>('.lang-switch').forEach((el) => {
      el.href = altUrl;
    });

    // Flag (muestra la bandera del idioma DESTINO)
    const targetLang = isEn ? 'es' : 'en';
    document.querySelectorAll<HTMLImageElement>('.lang-flag').forEach((img) => {
      img.src = targetLang === 'en' ? '/icons/flag-uk.svg' : '/icons/flag-es.svg';
    });

    // Label del selector — desktop: 'EN'/'ES' · móvil: 'English'/'Español'
    const desktopLangSwitch = document.querySelector<HTMLElement>('.lang-switch:not(.lang-switch--mobile) .lang-label');
    if (desktopLangSwitch) desktopLangSwitch.textContent = targetLang === 'en' ? 'EN' : 'ES';

    const mobileLangLabel = document.querySelector<HTMLElement>('.lang-switch--mobile .lang-label');
    if (mobileLangLabel) mobileLangLabel.textContent = targetLang === 'en' ? 'English' : 'Español';
  }

  if (wrap && indicator && desktopLinks.length > 0) {
    document.addEventListener('astro:page-load', () => {
      syncHeaderToCurrentPage();
      const activeLink = desktopLinks.find((link) =>
        link.classList.contains('is-active'),
      );

      if (!indicatorReady) {
        // Primera carga: posicionar sin animación, luego activarla
        if (activeLink) setIndicatorToLink(activeLink);
        requestAnimationFrame(() => {
          indicator.classList.add('is-animated');
          indicatorReady = true;
        });
      } else {
        // Navegaciones posteriores: el header persiste, la barra ya está en la
        // posición anterior → animamos hasta el nuevo enlace activo
        if (activeLink) {
          setIndicatorToLink(activeLink);
        } else {
          indicator.style.width = '0';
        }
      }
    });

    window.addEventListener('resize', () => {
      const activeLink = desktopLinks.find((link) =>
        link.classList.contains('is-active'),
      );
      if (activeLink) setIndicatorToLink(activeLink);
    });
  }

  // ── Menú móvil ───────────────────────────────────────────────────────────
  // El overlay [data-mobile-menu] está fuera del <header transition:persist> y se
  // reemplaza en cada navegación: no cachear el nodo; siempre reconsultar el DOM.
  function getMobileMenu() {
    return document.querySelector<HTMLElement>('[data-mobile-menu]');
  }

  function syncMobileMenuChromeOffset() {
    const header = document.querySelector<HTMLElement>('[data-header]');
    if (!header) return;
    const bottom = header.getBoundingClientRect().bottom;
    const clamped = Math.max(48, Math.min(bottom, 220));
    document.documentElement.style.setProperty(
      '--mobile-menu-chrome-offset',
      `${Math.round(clamped * 10) / 10}px`,
    );
  }

  function updateMenuToggleA11y(open: boolean) {
    const toggle = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
    if (!toggle) return;
    const openLbl = toggle.getAttribute('data-label-open');
    const closeLbl = toggle.getAttribute('data-label-close');
    if (openLbl && closeLbl) {
      toggle.setAttribute('aria-label', open ? closeLbl : openLbl);
    }
  }

  /** (n-1)*40ms + 200ms por ítem; divider/lang hasta ~380ms + margen */
  const MENU_CLOSE_TOTAL_MS = 420;

  let mobileMenuCloseTimer: ReturnType<typeof setTimeout> | null = null;

  function prefersReducedMotionMenu(): boolean {
    return window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  }

  function finalizeMobileMenuClose() {
    if (mobileMenuCloseTimer) {
      clearTimeout(mobileMenuCloseTimer);
      mobileMenuCloseTimer = null;
    }
    const mobileMenu = getMobileMenu();
    if (!mobileMenu) return;
    mobileMenu.classList.remove('is-open', 'mobile-menu--closing');
    mobileMenu.setAttribute('aria-hidden', 'true');
    document.querySelectorAll<HTMLElement>('[data-menu-toggle]').forEach((toggle) => {
      toggle.setAttribute('aria-expanded', 'false');
    });
    updateMenuToggleA11y(false);
    document.documentElement.style.removeProperty('--mobile-menu-chrome-offset');
    document.body.style.overflow = '';
  }

  function setMobileMenuOpen(open: boolean) {
    const mobileMenu = getMobileMenu();
    if (!mobileMenu) return;

    if (open) {
      if (mobileMenuCloseTimer) {
        clearTimeout(mobileMenuCloseTimer);
        mobileMenuCloseTimer = null;
      }
      mobileMenu.classList.remove('mobile-menu--closing');
      syncMobileMenuChromeOffset();
      requestAnimationFrame(() => syncMobileMenuChromeOffset());
      mobileMenu.classList.add('is-open');
      mobileMenu.setAttribute('aria-hidden', 'false');
      document.querySelectorAll<HTMLElement>('[data-menu-toggle]').forEach((toggle) => {
        toggle.setAttribute('aria-expanded', 'true');
      });
      updateMenuToggleA11y(true);
      document.body.style.overflow = 'hidden';
      return;
    }

    if (!mobileMenu.classList.contains('is-open')) return;

    if (mobileMenu.classList.contains('mobile-menu--closing')) {
      finalizeMobileMenuClose();
      return;
    }

    if (prefersReducedMotionMenu()) {
      finalizeMobileMenuClose();
      return;
    }

    mobileMenu.classList.add('mobile-menu--closing');
    mobileMenuCloseTimer = setTimeout(() => {
      mobileMenuCloseTimer = null;
      finalizeMobileMenuClose();
    }, MENU_CLOSE_TOTAL_MS);
  }

  function onMobileMenuLayoutResize() {
    if (getMobileMenu()?.classList.contains('is-open')) {
      syncMobileMenuChromeOffset();
    }
  }

  function toggleMobileMenu() {
    const mobileMenu = getMobileMenu();
    if (!mobileMenu) return;
    if (mobileMenu.classList.contains('mobile-menu--closing')) {
      if (mobileMenuCloseTimer) {
        clearTimeout(mobileMenuCloseTimer);
        mobileMenuCloseTimer = null;
      }
      mobileMenu.classList.remove('mobile-menu--closing');
      return;
    }
    if (mobileMenu.classList.contains('is-open')) {
      setMobileMenuOpen(false);
    } else {
      setMobileMenuOpen(true);
    }
  }

  /**
   * Handler principal: `pointerup` se dispara de forma fiable en
   * TODOS los dispositivos (touch + mouse) y NO requiere dos toques
   * en iOS Safari como `click` puede requerir con elementos con
   * :hover CSS o post-animación.
   */
  function onMobileMenuPointerUp(e: PointerEvent) {
    const target = e.target as Element | null;
    if (!target) return;

    if (target.closest('[data-menu-toggle]')) {
      e.preventDefault();
      toggleMobileMenu();
      return;
    }
    if (target.closest('[data-mobile-menu-dismiss]')) {
      setMobileMenuOpen(false);
      return;
    }
  }

  /**
   * `click` se mantiene para:
   * - Accesibilidad (teclado/screen reader)
   * - Enlaces de navegación del menú (.mobile-link)
   */
  function onMobileMenuClick(e: MouseEvent) {
    const target = e.target as Element | null;
    if (!target) return;

    if (target.closest('[data-mobile-link]')) {
      setMobileMenuOpen(false);
    }
  }

  document.addEventListener('pointerup', onMobileMenuPointerUp);
  document.addEventListener('click', onMobileMenuClick);

  document.addEventListener('click', (e) => {
    const target = e.target as Element | null;
    if (target?.closest('a.header-logo')) {
      try { sessionStorage.setItem('ph-logo-reveal-request', '1'); } catch {}
    }
  });

  document.addEventListener('astro:page-load', () => finalizeMobileMenuClose());

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') setMobileMenuOpen(false);
  });

  window.addEventListener('resize', () => {
    if (window.innerWidth >= 768) setMobileMenuOpen(false);
    else onMobileMenuLayoutResize();
  });

  window.visualViewport?.addEventListener('resize', onMobileMenuLayoutResize);
  window.addEventListener('orientationchange', onMobileMenuLayoutResize);
</script>
