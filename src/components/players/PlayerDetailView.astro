---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { CollectionEntry } from 'astro:content';
import type { Lang } from '@/i18n/utils';
import type { PlayerDetailPayload } from '@/lib/playerDetail';
import { formatNationalTeamAriaLabel } from '@/lib/countryLabels';
import { nationalTeamBadgeSrc } from '@/lib/nationalTeamBadge';

/** `?url` para placeholder SVG */
import placeholderSrc from '@/assets/images/players/avatar-placeholder.svg?url';

interface Props {
  lang: Lang;
  payload: PlayerDetailPayload;
  /** Foto: asset por slug o imagen de la colección Markdown */
  photo?: ImageMetadata;
  collectionEntry: CollectionEntry<'players'> | null;
  backHref: string;
  backLabel: string;
  bioEmptyLabel: string;
}

const { lang, payload, photo, collectionEntry, backHref, backLabel, bioEmptyLabel } = Astro.props;

const { name, subtitle, nationalTeamCodes, contentHtml } = payload;
const badgeItems = nationalTeamCodes
  .map((code) => {
    const src = nationalTeamBadgeSrc(code);
    return src ? { code, src } : null;
  })
  .filter((x): x is { code: string; src: string } => x !== null);
const nationalTeamAriaLabel =
  nationalTeamCodes.length > 0 ? formatNationalTeamAriaLabel(nationalTeamCodes, lang) : undefined;
const showBadges = badgeItems.length > 0 && Boolean(nationalTeamAriaLabel);

const alt = `${name} — ${subtitle}`;
const hasBio = contentHtml.trim().length > 0;

const resolvedPhoto: ImageMetadata | undefined =
  photo ?? (collectionEntry ? collectionEntry.data.photo : undefined);
---

<article class="player-detail">
  <p class="player-detail-back">
    <a href={backHref} class="player-detail-back-link">{backLabel}</a>
  </p>

  <div class="player-detail-hero">
    <div class="player-detail-photo-wrap">
      {
        resolvedPhoto ? (
          <Image
            src={resolvedPhoto}
            alt={alt}
            class="player-detail-photo"
            widths={[480, 640, 960]}
            sizes="(max-width: 768px) 100vw, 360px"
          />
        ) : (
          <img
            src={placeholderSrc}
            alt={alt}
            class="player-detail-photo player-detail-photo--placeholder"
            width={480}
            height={640}
            loading="eager"
            decoding="async"
          />
        )
      }
      {
        showBadges ? (
          <div class="player-detail-national-badges" role="group" aria-label={nationalTeamAriaLabel}>
            {badgeItems.map(({ code, src }) => (
              <img
                src={src}
                alt=""
                class="player-detail-national-badge"
                width="32"
                height="32"
                loading="lazy"
                decoding="async"
                data-national-code={code}
              />
            ))}
          </div>
        ) : null
      }
    </div>

    <div class="player-detail-meta">
      <h1 class="player-detail-name">{name}</h1>
      <p class="player-detail-subtitle">{subtitle}</p>
    </div>
  </div>

  <div class="player-detail-body">
    {
      hasBio ? (
        <div class="player-detail-prose" set:html={contentHtml} />
      ) : (
        <p class="player-detail-empty">{bioEmptyLabel}</p>
      )
    }
  </div>
</article>

<style>
  .player-detail {
    max-width: 48rem;
    margin-inline: auto;
  }

  .player-detail-back {
    margin: 0 0 1.5rem;
  }

  .player-detail-back-link {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-ph-gold);
    text-decoration: none;
    transition: color 200ms var(--ease-ph);
  }

  .player-detail-back-link:hover {
    color: var(--color-ph-white);
  }

  .player-detail-hero {
    display: grid;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  @media (min-width: 768px) {
    .player-detail-hero {
      grid-template-columns: min(280px, 42vw) 1fr;
      align-items: start;
      gap: 2rem;
    }
  }

  .player-detail-photo-wrap {
    position: relative;
    aspect-ratio: 3 / 4;
    max-width: 320px;
    margin-inline: auto;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--color-ph-white-10);
    background: var(--color-ph-white-10);
  }

  @media (min-width: 768px) {
    .player-detail-photo-wrap {
      margin-inline: 0;
    }
  }

  .player-detail-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .player-detail-photo--placeholder {
    object-fit: cover;
    object-position: center top;
    background: var(--color-ph-black);
  }

  .player-detail-national-badges {
    position: absolute;
    bottom: 0.625rem;
    right: 0.625rem;
    z-index: 2;
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.35rem;
    pointer-events: none;
  }

  .player-detail-national-badge {
    width: 2rem;
    height: 2rem;
    object-fit: contain;
    border-radius: 3px;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.35);
    background: rgba(13, 15, 18, 0.35);
  }

  .player-detail-meta {
    text-align: center;
  }

  @media (min-width: 768px) {
    .player-detail-meta {
      text-align: start;
      padding-top: 0.5rem;
    }
  }

  .player-detail-name {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-ph-white);
    margin: 0;
  }

  .player-detail-subtitle {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ph-gold);
    margin: 0.75rem 0 0;
  }

  .player-detail-body {
    padding-top: 1rem;
    border-top: 1px solid var(--color-ph-white-10);
  }

  .player-detail-empty {
    margin: 0;
    font-size: 1rem;
    color: var(--color-ph-white-60);
    line-height: 1.6;
  }

  .player-detail-prose {
    font-size: 1rem;
    color: var(--color-ph-white-80);
    line-height: 1.65;
  }

  .player-detail-prose :global(p) {
    margin: 0 0 1rem;
  }

  .player-detail-prose :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
