---
import { useTranslations, type Lang } from '@/i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const blocks = [
  { number: '01', title: t('about.block1.title'), body: t('about.block1.body') },
  { number: '02', title: t('about.block2.title'), body: t('about.block2.body') },
  { number: '03', title: t('about.block3.title'), body: t('about.block3.body') },
];
---

<section class="about-section">
  <div class="ph-section">
    <header class="about-header">
      <span class="ph-label">{t('nav.about')}</span>
      <div class="ph-divider mt-4"></div>
      <h1 class="about-title">
        {t('about.title')}
      </h1>
      <p class="about-subtitle">
        {t('about.subtitle')}
      </p>
    </header>

    <div class="about-blocks">
      {blocks.map((block) => (
        <article class="about-block">
          <div class="about-block-left">
            <span class="about-num" aria-hidden="true">{block.number}</span>
            <h2 class="about-block-title">{block.title}</h2>
          </div>
          <div class="about-block-right">
            <div class="about-block-accent" aria-hidden="true"></div>
            <p class="about-block-body">{block.body}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .about-section {
    position: relative;
    background:
      radial-gradient(ellipse at 20% 80%, rgba(214, 178, 94, 0.025) 0%, transparent 50%),
      var(--ph-black);
  }

  .about-header {
    margin-bottom: 4rem;
  }

  @media (min-width: 1024px) {
    .about-header {
      margin-bottom: 5rem;
    }
  }

  .about-title {
    margin-top: 2rem;
    font-family: var(--ph-font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--ph-white);
  }

  .about-subtitle {
    margin-top: 1rem;
    max-width: 40rem;
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--ph-white-60);
  }

  @media (min-width: 1024px) {
    .about-subtitle {
      font-size: 1.125rem;
    }
  }

  .about-blocks {
    border-top: 1px solid var(--ph-white-10);
  }

  .about-block {
    display: grid;
    gap: 1.5rem;
    padding-block: 3.5rem;
    border-bottom: 1px solid var(--ph-white-10);
  }

  @media (min-width: 1024px) {
    .about-block {
      grid-template-columns: 1fr 2fr;
      gap: 4rem;
      align-items: baseline;
      padding-block: 4.5rem;
    }
  }

  .about-block-left {
    position: relative;
  }

  .about-num {
    position: absolute;
    top: -0.5rem;
    left: 0;
    font-family: var(--ph-font-display);
    font-size: 3.5rem;
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--ph-gold);
    opacity: 0.12;
    pointer-events: none;
  }

  @media (min-width: 1024px) {
    .about-num {
      font-size: 4.5rem;
      top: -0.75rem;
    }
  }

  .about-block-title {
    position: relative;
    margin-top: 1.5rem;
    font-family: var(--ph-font-display);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--ph-white);
  }

  @media (min-width: 1024px) {
    .about-block-title {
      margin-top: 2rem;
    }
  }

  .about-block-right {
    display: flex;
    gap: 1.5rem;
  }

  .about-block-accent {
    flex-shrink: 0;
    width: 2px;
    min-height: 100%;
    background: linear-gradient(
      to bottom,
      var(--ph-gold) 0%,
      var(--ph-gold-muted) 100%
    );
    opacity: 0.3;
    border-radius: 1px;
  }

  .about-block-body {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--ph-white-60);
    max-width: none;
  }

  @media (min-width: 1024px) {
    .about-block-body {
      font-size: 1.125rem;
      padding-top: 0.25rem;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import {
    reducedMotion,
    wrapWords,
    splitWords,
    trackingReveal,
    counterReveal,
  } from '@/scripts/ph-text-animations';

  function initAboutAnimations(): void {
    const section = document.querySelector<HTMLElement>('.about-section');
    if (!section || reducedMotion()) return;

    // ── Cabecera ────────────────────────────────────────────────────────────
    const label = section.querySelector<HTMLElement>('.ph-label');
    if (label) {
      trackingReveal(label, { trigger: label, start: 'top 88%', once: true });
    }

    const title = section.querySelector<HTMLElement>('.about-title');
    if (title) {
      const words = wrapWords(title);
      gsap.from(words, {
        yPercent: 115,
        duration: 0.85,
        stagger: 0.07,
        ease: 'power4.out',
        scrollTrigger: { trigger: title, start: 'top 82%', once: true },
      });
    }

    const subtitle = section.querySelector<HTMLElement>('.about-subtitle');
    if (subtitle) {
      const spans = splitWords(subtitle);
      gsap.from(spans, {
        opacity: 0,
        filter: 'blur(6px)',
        y: 6,
        duration: 0.6,
        stagger: 0.03,
        ease: 'power2.out',
        scrollTrigger: { trigger: subtitle, start: 'top 88%', once: true },
      });
    }

    // ── Bloques ─────────────────────────────────────────────────────────────
    section.querySelectorAll<HTMLElement>('.about-block').forEach((block, i) => {
      // Número decorativo: contador cinético
      const numEl = block.querySelector<HTMLElement>('.about-num');
      if (numEl) {
        counterReveal(numEl, i + 1, {
          trigger: block,
          start: 'top 82%',
          once: true,
        });
      }

      // Título del bloque: cortina por palabras
      const blockTitle = block.querySelector<HTMLElement>('.about-block-title');
      if (blockTitle) {
        const words = wrapWords(blockTitle);
        gsap.from(words, {
          yPercent: 115,
          duration: 0.8,
          stagger: 0.05,
          ease: 'power4.out',
          scrollTrigger: { trigger: blockTitle, start: 'top 82%', once: true },
        });
      }

      // Barra de acento: crece verticalmente
      const accent = block.querySelector<HTMLElement>('.about-block-accent');
      if (accent) {
        gsap.from(accent, {
          scaleY: 0,
          transformOrigin: 'top center',
          duration: 0.8,
          ease: 'expo.out',
          scrollTrigger: { trigger: block, start: 'top 78%', once: true },
        });
      }

      // Cuerpo del bloque: palabras con desenfoque
      const body = block.querySelector<HTMLElement>('.about-block-body');
      if (body) {
        const spans = splitWords(body);
        gsap.from(spans, {
          opacity: 0,
          filter: 'blur(6px)',
          y: 5,
          duration: 0.6,
          stagger: 0.025,
          ease: 'power2.out',
          scrollTrigger: { trigger: body, start: 'top 88%', once: true },
        });
      }
    });
  }

  document.addEventListener('astro:page-load', initAboutAnimations);
</script>
