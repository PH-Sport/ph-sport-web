---
import { useTranslations, type Lang } from '@/i18n/utils';
import { HERO_STATIC_IMAGE, HERO_VIDEO_POSTER, HERO_VIDEO_SOURCES } from '@/lib/heroMedia';

interface Props {
  lang: Lang;
  sectionId?: string;
}

const { lang, sectionId } = Astro.props;
const t = useTranslations(lang);
const staticBackdrop = HERO_STATIC_IMAGE.trim().length > 0 ? HERO_STATIC_IMAGE : null;
const videoPoster = HERO_VIDEO_POSTER.trim().length > 0 ? HERO_VIDEO_POSTER : undefined;
---

<section
  id={sectionId}
  class="hero hero--home"
>
  <div class="hero-media" aria-hidden="true">
    <div class="hero-video-fallback" />
    {staticBackdrop && (
      <img class="hero-static-image" src={staticBackdrop} alt="" width="1920" height="1080" loading="eager" fetchpriority="high" decoding="async" />
    )}
    <video class="hero-video" data-hero-video muted loop playsinline autoplay preload="auto" poster={videoPoster}>
      {HERO_VIDEO_SOURCES.map((s) => (
        <source src={s.src} type={s.type} />
      ))}
    </video>
  </div>

  <div class="hero-overlay" aria-hidden="true"></div>

  <div class="hero-content">
    <h1 class="hero-claim">
      <span class="hero-claim__lead">{t('hero.claim.lead')}</span>
      <span class="hero-claim__accent">{t('hero.claim.accent')}</span>
    </h1>
  </div>

  <a class="hero-scroll" href="#talentos" data-hero-scroll-indicator>
    <span class="hero-scroll__label">{t('hero.scroll.label')}</span>
    <span class="hero-scroll__line" aria-hidden="true"></span>
  </a>
</section>

<style>
  .hero--home {
    position: relative;
    width: 100%;
    min-height: 100svh;
    overflow: hidden;
    background: var(--color-ph-black, #0d0f12);
    color: var(--color-ph-white, #ffffff);
  }

  .hero-media {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .hero-video-fallback {
    position: absolute;
    inset: 0;
    z-index: 0;
    background:
      radial-gradient(ellipse at 70% 80%, rgba(214, 178, 94, 0.06) 0%, transparent 42%),
      radial-gradient(ellipse at 30% 20%, rgba(214, 178, 94, 0.10) 0%, transparent 48%),
      radial-gradient(ellipse at 50% 100%, rgba(13, 15, 18, 0.9) 0%, transparent 55%),
      var(--ph-section-bg, #0d0f12);
  }

  .hero-static-image {
    position: absolute;
    inset: 0;
    z-index: 1;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero-video {
    position: absolute;
    inset: 0;
    z-index: 2;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero--home .hero-video { display: none; }
  }
  .hero--home.hero--video-error .hero-video { display: none; }

  /* Dark gradient overlay for legibility of the claim over the video */
  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
    background:
      linear-gradient(180deg,
        rgba(13,15,18,0.55) 0%,
        rgba(13,15,18,0) 30%,
        rgba(13,15,18,0) 55%,
        rgba(13,15,18,0.85) 100%),
      linear-gradient(90deg,
        rgba(13,15,18,0.35) 0%,
        rgba(13,15,18,0) 55%);
  }

  .hero-content {
    position: absolute;
    left: var(--ph-section-px, clamp(20px, 4vw, 48px));
    right: var(--ph-section-px, clamp(20px, 4vw, 48px));
    bottom: clamp(72px, 10vw, 140px);
    z-index: 4;
    max-width: 980px;
  }

  .hero-claim {
    font-family: var(--font-display, 'Inter Tight', sans-serif);
    font-weight: 500;
    font-size: clamp(44px, 8.5vw, 132px);
    letter-spacing: -0.03em;
    line-height: 0.96;
    margin: 0;
    text-wrap: balance;
  }
  .hero-claim__lead {
    display: block;
    color: var(--color-ph-white, #ffffff);
  }
  .hero-claim__accent {
    display: block;
    color: var(--color-ph-gold, #d6b25e);
    font-style: italic;
    font-weight: 400;
  }

  /* Vertical scroll cue — bottom-right */
  .hero-scroll {
    position: absolute;
    right: var(--ph-section-px, clamp(20px, 4vw, 48px));
    bottom: clamp(24px, 4vw, 48px);
    z-index: 4;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    color: var(--color-ph-white, #ffffff);
    opacity: 0.7;
    transition: opacity 0.2s ease, color 0.2s ease;
    text-decoration: none;
  }
  .hero-scroll:hover {
    opacity: 1;
    color: var(--color-ph-gold, #d6b25e);
  }
  .hero-scroll__label {
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }
  .hero-scroll__line {
    position: relative;
    width: 1px;
    height: 56px;
    background: currentColor;
    overflow: hidden;
  }
  .hero-scroll__line::after {
    content: "";
    position: absolute;
    top: -100%;
    left: 0;
    width: 1px;
    height: 60%;
    background: var(--color-ph-gold, #d6b25e);
    animation: heroScrollCue 2.4s cubic-bezier(.7,0,.2,1) infinite;
  }
  @keyframes heroScrollCue {
    0% { transform: translateY(0); }
    100% { transform: translateY(260%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-scroll__line::after { animation: none; }
  }

  .hero-scroll.is-hidden {
    opacity: 0;
    pointer-events: none;
  }

  @media (max-width: 720px) {
    .hero-content { bottom: clamp(96px, 18vh, 160px); }
  }
</style>

<script>
  function initHeroScrollCue(): void {
    const cue = document.querySelector<HTMLElement>('[data-hero-scroll-indicator]');
    if (!cue) return;
    const toggle = () => cue.classList.toggle('is-hidden', window.scrollY > 48);
    toggle();
    document.addEventListener('scroll', toggle, { passive: true });
  }

  function initHeroVideo(): void {
    const hero = document.querySelector<HTMLElement>('.hero--home');
    const video = document.querySelector<HTMLVideoElement>('[data-hero-video]');
    if (!hero || !video) return;
    const markStatic = () => hero.classList.add('hero--video-error');
    video.addEventListener('error', markStatic);
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    void video.play().catch(() => markStatic());
  }

  document.addEventListener('astro:page-load', () => {
    initHeroScrollCue();
    initHeroVideo();
  });
</script>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { reducedMotion, wrapWords } from '@/scripts/ph-text-animations';

  gsap.registerPlugin(ScrollTrigger);

  function initHeroAnimations(): void {
    const hero = document.querySelector<HTMLElement>('.hero--home');
    if (!hero) return;
    if (reducedMotion()) return;

    const lead = hero.querySelector<HTMLElement>('.hero-claim__lead');
    const accent = hero.querySelector<HTMLElement>('.hero-claim__accent');
    const claim = hero.querySelector<HTMLElement>('.hero-claim');
    const scroll = hero.querySelector<HTMLElement>('.hero-scroll');

    if (lead) {
      const words = wrapWords(lead);
      gsap.from(words, {
        yPercent: 115,
        duration: 1.0,
        ease: 'power4.out',
        stagger: 0.08,
        delay: 0.2,
      });
    }
    if (accent) {
      const words = wrapWords(accent);
      gsap.from(words, {
        yPercent: 115,
        duration: 1.0,
        ease: 'power4.out',
        stagger: 0.08,
        delay: 0.4,
      });
    }
    if (scroll) {
      gsap.from(scroll, { opacity: 0, y: 12, duration: 0.8, ease: 'power2.out', delay: 0.9 });
    }
    if (claim) {
      ScrollTrigger.create({
        trigger: hero,
        start: 'top top',
        end: 'bottom top',
        scrub: 0.8,
        onUpdate: (self) => {
          gsap.set(claim, { yPercent: self.progress * 20 });
        },
      });
    }

    requestAnimationFrame(() => ScrollTrigger.refresh());
  }

  document.addEventListener('astro:page-load', initHeroAnimations);
</script>
