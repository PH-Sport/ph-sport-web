---
import jugadoresData from '../../../data/jugadores.json';
import entrenadoresData from '../../../data/entrenadores.json';
import { useTranslations, type Lang } from '@/i18n/utils';
import { formatNationalTeamAriaLabel } from '@/lib/countryLabels';
import { getPlayerPhotoBySlug } from '@/lib/playerPhotos';
import { parseSortParam, sortRosterByName } from '@/lib/sortRoster';
import { slugify } from '@/lib/slugify';
import { buildPlayerDetailPayloadsForLang } from '@/lib/playerDetail';
import PortraitCard from '@/components/ui/PortraitCard.astro';
import PlayersSortRow from '@/components/ui/PlayersSortRow.astro';
import PlayersViewDropdown from '@/components/ui/PlayersViewDropdown.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const playerPayloads = await buildPlayerDetailPayloadsForLang(lang);
const playerPayloadsJson = JSON.stringify(playerPayloads);
const detailBase = lang === 'es' ? '/jugadores' : '/en/players';

/** Orden = orden de los arrays en `data/jugadores.json` y `data/entrenadores.json` (directiva). */
const rosterPlayers = jugadoresData.map((row) => ({
  ...row,
  role: 'player' as const,
  slug: slugify(row.name),
}));

const rosterCoaches = entrenadoresData.map((row) => ({
  ...row,
  role: 'coach' as const,
  slug: slugify(row.name),
}));

const sortMode = parseSortParam(Astro.url.searchParams.get('sort'));
const displayPlayers = sortRosterByName(rosterPlayers, sortMode, lang);
const displayCoaches = sortRosterByName(rosterCoaches, sortMode, lang);

const totalRoster = rosterPlayers.length + rosterCoaches.length;

const hasPlayers = rosterPlayers.length > 0;
const hasCoaches = rosterCoaches.length > 0;
const showTabs = hasPlayers && hasCoaches;

/** ?view=coaches | entrenadores → pestaña entrenadores; resto → jugadores */
const viewParam = Astro.url.searchParams.get('view');
const coachesTabFromUrl =
  viewParam === 'coaches' || viewParam === 'entrenadores';
const showCoachesPanelFirst = showTabs && coachesTabFromUrl;

function subtitleFor(row: { club: { name: string } | null }): string {
  return row.club?.name ?? t('players.club.none');
}

---

<section
  class="players-section"
  data-players-tabs={showTabs ? 'true' : undefined}
  data-label-players={showTabs ? t('players.subsection.players') : undefined}
  data-label-coaches={showTabs ? t('players.subsection.coaches') : undefined}
  data-tabs-aria={showTabs ? t('players.tabs.aria') : undefined}
  data-player-detail-base={detailBase}
  data-player-modal-close={t('a11y.close')}
  data-player-payloads={playerPayloadsJson}
>
  <div class="ph-section">
    <header class="players-header">
      <div class="players-header-top">
        <span class="ph-label">{t('nav.players')}</span>
      </div>
      <div class="ph-divider mt-4"></div>
      <h2 class="players-title">
        {t('players.title')}
      </h2>
      <p class="players-subtitle">{t('players.subtitle')}</p>
    </header>

    {
      totalRoster === 0 && (
        <p class="players-empty">{t('players.empty')}</p>
      )
    }

    {
      showTabs && (
        <div class="players-tabs-wrap">
          <div class="players-toolbar-mobile md:hidden" data-players-toolbar-animate>
            <div class="players-toolbar-mobile-view">
              <PlayersViewDropdown lang={lang} showCoachesPanelFirst={showCoachesPanelFirst} />
            </div>
            <div class="players-toolbar-mobile-sort">
              <PlayersSortRow lang={lang} sortMode={sortMode} idSuffix="-mobile" />
            </div>
          </div>

          <div class="players-toolbar players-toolbar--desktop hidden md:flex">
            <div class="players-tabs" role="tablist" aria-label={t('players.tabs.aria')}>
              <button
                type="button"
                class="players-tab ph-ui-btn ph-ui-btn--secondary"
                role="tab"
                id="players-tab-players"
                aria-selected={showCoachesPanelFirst ? 'false' : 'true'}
                aria-controls="players-panel-players"
                tabindex={showCoachesPanelFirst ? -1 : 0}
                data-tab="players"
              >
                <span class="players-tab-label">{t('players.subsection.players')}</span>
              </button>
              <button
                type="button"
                class="players-tab ph-ui-btn ph-ui-btn--secondary"
                role="tab"
                id="players-tab-coaches"
                aria-selected={showCoachesPanelFirst ? 'true' : 'false'}
                aria-controls="players-panel-coaches"
                tabindex={showCoachesPanelFirst ? 0 : -1}
                data-tab="coaches"
              >
                <span class="players-tab-label">{t('players.subsection.coaches')}</span>
              </button>
            </div>
            <PlayersSortRow lang={lang} sortMode={sortMode} />
          </div>

          <div
            class="players-tabpanel"
            id="players-panel-players"
            role="tabpanel"
            aria-labelledby="players-tab-players"
            hidden={showCoachesPanelFirst ? true : undefined}
          >
            <div class="players-grid">
              {displayPlayers.map((player) => (
                <PortraitCard
                  name={player.name}
                  subtitle={subtitleFor(player)}
                  photo={getPlayerPhotoBySlug(player.slug)}
                  href={`${detailBase}/${player.slug}`}
                  dataSlug={player.slug}
                  nationalTeamCodes={player.nationalTeamCodes ?? []}
                  nationalTeamAriaLabel={formatNationalTeamAriaLabel(player.nationalTeamCodes ?? [], lang)}
                />
              ))}
            </div>
          </div>

          <div
            class="players-tabpanel"
            id="players-panel-coaches"
            role="tabpanel"
            aria-labelledby="players-tab-coaches"
            hidden={showCoachesPanelFirst ? undefined : true}
          >
            <div class="players-grid">
              {displayCoaches.map((coach) => (
                <PortraitCard
                  name={coach.name}
                  subtitle={subtitleFor(coach)}
                  photo={getPlayerPhotoBySlug(coach.slug)}
                  href={`${detailBase}/${coach.slug}`}
                  dataSlug={coach.slug}
                  nationalTeamCodes={coach.nationalTeamCodes ?? []}
                  nationalTeamAriaLabel={formatNationalTeamAriaLabel(coach.nationalTeamCodes ?? [], lang)}
                />
              ))}
            </div>
          </div>
        </div>
      )
    }

    {
      !showTabs && hasPlayers && (
        <div class="players-subsection">
          <div class="players-subsection-toolbar">
            <div class="players-subsection-head">
              <h3 class="players-section-title">{t('players.subsection.players')}</h3>
            </div>
            <PlayersSortRow lang={lang} sortMode={sortMode} />
          </div>
          <div class="players-grid">
            {displayPlayers.map((player) => (
              <PortraitCard
                name={player.name}
                subtitle={subtitleFor(player)}
                photo={getPlayerPhotoBySlug(player.slug)}
                href={`${detailBase}/${player.slug}`}
                dataSlug={player.slug}
                nationalTeamCodes={player.nationalTeamCodes ?? []}
                nationalTeamAriaLabel={formatNationalTeamAriaLabel(player.nationalTeamCodes ?? [], lang)}
              />
            ))}
          </div>
        </div>
      )
    }

    {
      !showTabs && !hasPlayers && hasCoaches && (
        <div class="players-subsection">
          <div class="players-subsection-toolbar">
            <div class="players-subsection-head">
              <h3 class="players-section-title">{t('players.subsection.coaches')}</h3>
            </div>
            <PlayersSortRow lang={lang} sortMode={sortMode} />
          </div>
          <div class="players-grid">
            {displayCoaches.map((coach) => (
              <PortraitCard
                name={coach.name}
                subtitle={subtitleFor(coach)}
                photo={getPlayerPhotoBySlug(coach.slug)}
                href={`${detailBase}/${coach.slug}`}
                dataSlug={coach.slug}
                nationalTeamCodes={coach.nationalTeamCodes ?? []}
                nationalTeamAriaLabel={formatNationalTeamAriaLabel(coach.nationalTeamCodes ?? [], lang)}
              />
            ))}
          </div>
        </div>
      )
    }
  </div>
</section>

<style>
  .players-section {
    position: relative;
    background:
      radial-gradient(ellipse at 50% 0%, rgba(214, 178, 94, 0.02) 0%, transparent 50%),
      var(--ph-black);
  }

  .players-header {
    margin-bottom: 3rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--ph-white-10);
  }

  @media (min-width: 1024px) {
    .players-header {
      margin-bottom: 4rem;
      padding-bottom: 3rem;
    }
  }

  .players-header-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .players-title {
    margin-top: 2rem;
    font-family: var(--ph-font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--ph-white);
  }

  .players-subtitle {
    margin-top: 1rem;
    font-size: 1.0625rem;
    color: var(--ph-white-60);
  }

  .players-empty {
    margin: 0;
    font-size: 1rem;
    color: var(--ph-white-60);
  }

  /* ── Pestañas jugadores / entrenadores ── */
  .players-tabs-wrap {
    margin-top: 2rem;
  }

  @media (min-width: 1024px) {
    .players-tabs-wrap {
      margin-top: 2.5rem;
    }
  }

  .players-tabs {
    display: flex;
    flex-wrap: nowrap;
    align-items: stretch;
    gap: 0.26rem;
    box-sizing: border-box;
    min-width: 0;
    max-width: 100%;
  }

  .players-tab {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
  }

  .players-tab-label {
    display: inline-flex;
    align-items: center;
    min-width: 0;
  }

  @media (max-width: 639px) {
    .players-toolbar--desktop .players-tabs .players-tab {
      flex: 1 1 0;
      min-width: 0;
    }

    .players-toolbar--desktop .players-tab {
      font-size: 0.6875rem;
      padding-inline: 0.45rem;
    }
  }

  .players-tab[aria-selected='true'] {
    border-color: rgba(214, 178, 94, 0.35);
    color: var(--ph-white);
    background: rgba(214, 178, 94, 0.1);
  }

  .players-tab[aria-selected='true']::before {
    transform: scaleX(0);
  }

  .players-tab[aria-selected='true']:hover {
    border-color: rgba(214, 178, 94, 0.45);
    color: var(--ph-white);
  }

  .players-tab[aria-selected='true']:hover::before {
    transform: scaleX(0);
  }

  /* Móvil: dropdown vista + dropdown Orden (solo < md; no usar display:flex global para no pisar `md:hidden` de Tailwind) */
  @media (max-width: 767px) {
    .players-toolbar-mobile {
      position: relative;
      z-index: 50;
      display: flex;
      align-items: stretch;
      justify-content: space-between;
      gap: 0.5rem;
      width: 100%;
    }
  }

  .players-toolbar-mobile-view {
    position: relative;
    z-index: 55;
    flex: 1 1 auto;
    min-width: 0;
  }

  /* Mismo patrón dropdown que desktop; panel anclado al botón (derecha) */
  .players-toolbar-mobile-sort {
    position: relative;
    z-index: 60;
    flex: 0 0 auto;
    align-self: stretch;
    display: flex;
    align-items: stretch;
    min-width: 0;
  }

  .players-toolbar-mobile-sort :global([data-players-sort-root]) {
    display: flex;
    align-items: stretch;
  }

  .players-toolbar-mobile-sort :global(.players-sort-dropdown) {
    display: flex;
    align-items: stretch;
  }

  .players-toolbar-mobile-sort :global(.players-sort-trigger) {
    min-height: 100%;
    padding-inline: 0.45rem;
  }

  .players-toolbar-mobile-sort :global(.players-sort-label) {
    font-size: 0.6875rem;
  }

  .players-toolbar-mobile-sort :global(.players-sort-panel) {
    z-index: 120;
  }

  /* Desktop: pestañas + orden en barra (display solo ≥ md: si ponemos flex aquí sin media, gana a `hidden` de Tailwind y el bloque se ve también en móvil) */
  .players-toolbar--desktop {
    position: relative;
    z-index: 50;
    width: 100%;
  }

  @media (min-width: 768px) {
    .players-toolbar--desktop {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      gap: 1rem 1.5rem;
    }

    .players-toolbar--desktop .players-tabs {
      flex: 0 1 auto;
      min-width: 0;
    }

    .players-toolbar--desktop .players-sort-root {
      margin-top: 0;
      margin-bottom: 0;
      flex: 0 0 auto;
      margin-left: 0;
      align-self: center;
    }
  }

  .players-subsection-toolbar {
    position: relative;
    z-index: 50;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem 1.5rem;
    width: 100%;
    margin-bottom: 1.5rem;
  }

  .players-subsection-toolbar .players-subsection-head {
    margin-bottom: 0;
    flex: 1 1 auto;
    min-width: min(100%, 12rem);
  }

  .players-subsection-toolbar .players-sort-root {
    margin-top: 0;
    margin-bottom: 0;
    flex: 0 0 auto;
    align-items: center;
  }

  @media (max-width: 639px) {
    .players-subsection-toolbar {
      flex-wrap: wrap;
      gap: 0.75rem;
    }

    .players-subsection-toolbar .players-subsection-head {
      flex: 1 1 100%;
      min-width: 0;
    }

    .players-subsection-toolbar .players-sort-root {
      flex: 0 0 auto;
      margin-left: auto;
    }
  }

  .players-tabpanel {
    margin-top: 1.75rem;
  }

  .players-tabs-wrap .players-tabpanel {
    margin-top: 1.25rem;
  }

  .players-tabpanel[hidden] {
    display: none !important;
  }

  .players-subsection {
    margin-top: 2.5rem;
  }

  .players-subsection:first-of-type {
    margin-top: 0;
  }

  .players-subsection:not(:first-of-type) {
    margin-top: 3rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--ph-white-10);
  }

  @media (min-width: 1024px) {
    .players-subsection:not(:first-of-type) {
      margin-top: 3.5rem;
      padding-top: 3rem;
    }
  }

  .players-subsection-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .players-section-title {
    margin: 0;
    font-family: var(--ph-font-display);
    font-size: clamp(1.125rem, 2.5vw, 1.375rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--ph-white);
  }

  .players-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  @media (min-width: 768px) {
    .players-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }
  }

  @media (min-width: 1024px) {
    .players-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 1.5rem;
    }
  }
</style>


<script>
  import { gsap } from 'gsap';
  import {
    reducedMotion,
    wrapWords,
    splitWords,
    trackingReveal,
  } from '@/scripts/ph-text-animations';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { initPlayerModal } from '@/scripts/player-modal';

  gsap.registerPlugin(ScrollTrigger);

  function initPlayersTabSwitch(): void {
    const section = document.querySelector<HTMLElement>('.players-section[data-players-tabs="true"]');
    if (!section) return;

    const desktopTabs = section.querySelectorAll<HTMLButtonElement>('.players-tab[role="tab"]');
    const panels = section.querySelectorAll<HTMLElement>('.players-tabpanel');

    let tabAnimating = false;

    function getTabId(btn: HTMLButtonElement): 'players' | 'coaches' {
      const v = btn.dataset.tab;
      return v === 'coaches' ? 'coaches' : 'players';
    }

    function getViewTabId(btn: HTMLButtonElement): 'players' | 'coaches' {
      const v = btn.dataset.viewTab;
      return v === 'coaches' ? 'coaches' : 'players';
    }

    function viewParamForTab(id: 'players' | 'coaches'): string {
      return id === 'coaches' ? 'coaches' : 'players';
    }

    function panelEl(id: 'players' | 'coaches'): HTMLElement | null {
      return section.querySelector<HTMLElement>(
        id === 'coaches' ? '#players-panel-coaches' : '#players-panel-players',
      );
    }

    function closeViewDropdownIfOpen(): void {
      section.querySelectorAll<HTMLElement>('[data-players-view-dropdown]').forEach((root) => {
        const panel = root.querySelector<HTMLElement>('.players-view-panel');
        const trigger = root.querySelector<HTMLButtonElement>('.players-view-trigger');
        if (!panel || panel.hidden) return;
        if (reducedMotion()) {
          panel.hidden = true;
          trigger?.setAttribute('aria-expanded', 'false');
          return;
        }
        gsap.killTweensOf(panel);
        panel.hidden = true;
        trigger?.setAttribute('aria-expanded', 'false');
        gsap.set(panel, { clearProps: 'all' });
      });
    }

    function applyTabDOM(active: 'players' | 'coaches'): void {
      closeViewDropdownIfOpen();

      desktopTabs.forEach((btn) => {
        const id = getTabId(btn);
        const isSel = id === active;
        btn.setAttribute('aria-selected', String(isSel));
        btn.tabIndex = isSel ? 0 : -1;
      });

      section.querySelectorAll<HTMLButtonElement>('.players-view-option[data-view-tab]').forEach((btn) => {
        const id = getViewTabId(btn);
        const isSel = id === active;
        btn.setAttribute('aria-selected', String(isSel));
      });

      const lp = section.dataset.labelPlayers;
      const lc = section.dataset.labelCoaches;
      const tabsAria = section.dataset.tabsAria;
      const triggerLabel = section.querySelector('#players-view-trigger-mobile-label');
      const trigger = section.querySelector<HTMLButtonElement>('#players-view-trigger-mobile');
      if (triggerLabel && lp && lc) {
        triggerLabel.textContent = active === 'coaches' ? lc : lp;
      }
      if (trigger && lp && lc && tabsAria) {
        const label = active === 'coaches' ? lc : lp;
        trigger.setAttribute('aria-label', `${tabsAria}: ${label}`);
      }

      panels.forEach((panel) => {
        const pid = panel.id === 'players-panel-coaches' ? 'coaches' : 'players';
        panel.hidden = pid !== active;
      });

      const url = new URL(window.location.href);
      url.searchParams.set('view', viewParamForTab(active));
      history.replaceState(null, '', url.pathname + url.search + url.hash);

      requestAnimationFrame(() => {
        ScrollTrigger.refresh();
      });
    }

    function animateCardsIn(panel: HTMLElement | null): void {
      if (!panel) return;
      const newCards = panel.querySelectorAll<HTMLElement>('.card');
      if (!newCards.length) return;
      gsap.killTweensOf(newCards);
      gsap.set(newCards, { opacity: 0, y: 18 });
      gsap.to(newCards, {
        opacity: 1,
        y: 0,
        duration: 0.48,
        stagger: { each: 0.055, from: 'start' },
        ease: 'power3.out',
        onComplete: () => {
          gsap.set(newCards, { clearProps: 'opacity,transform' });
        },
      });
    }

    function activateTab(active: 'players' | 'coaches'): void {
      const selected = section.querySelector<HTMLButtonElement>('.players-tab[aria-selected="true"]');
      const prev: 'players' | 'coaches' = selected ? getTabId(selected) : 'players';
      if (prev === active) return;
      if (tabAnimating) return;

      if (reducedMotion()) {
        applyTabDOM(active);
        return;
      }

      const oldPanel = panelEl(prev);
      const oldCards = oldPanel?.querySelectorAll<HTMLElement>('.card') ?? [];

      tabAnimating = true;

      const doneSwitch = (): void => {
        applyTabDOM(active);
        animateCardsIn(panelEl(active));
        tabAnimating = false;
      };

      if (oldCards.length) {
        gsap.killTweensOf(oldCards);
        gsap.to(oldCards, {
          opacity: 0,
          duration: 0.22,
          ease: 'power2.in',
          onComplete: () => {
            gsap.set(oldCards, { clearProps: 'opacity' });
            doneSwitch();
          },
        });
      } else {
        doneSwitch();
      }
    }

    desktopTabs.forEach((btn) => {
      btn.addEventListener('click', () => {
        activateTab(getTabId(btn));
      });
    });

    section.addEventListener(
      'players:activate-tab',
      ((e: Event) => {
        const ce = e as CustomEvent<{ tab: 'players' | 'coaches' }>;
        const tab = ce.detail?.tab;
        if (tab === 'players' || tab === 'coaches') {
          activateTab(tab);
        }
      }) as EventListener,
    );

    const tablist = section.querySelector<HTMLElement>('[role="tablist"]');
    if (tablist) {
      tablist.addEventListener('keydown', (e) => {
        const keys = ['ArrowLeft', 'ArrowRight', 'Home', 'End'];
        if (!keys.includes(e.key)) return;
        const list = Array.from(desktopTabs);
        const ix = list.findIndex((t) => t.getAttribute('aria-selected') === 'true');
        if (ix < 0) return;
        let next = ix;
        if (e.key === 'ArrowRight') next = (ix + 1) % list.length;
        if (e.key === 'ArrowLeft') next = (ix - 1 + list.length) % list.length;
        if (e.key === 'Home') next = 0;
        if (e.key === 'End') next = list.length - 1;
        if (next !== ix) {
          e.preventDefault();
          activateTab(getTabId(list[next]!));
          list[next]!.focus();
        }
      });
    }
  }

  function initPlayersViewDropdown(): void {
    const section = document.querySelector<HTMLElement>('.players-section[data-players-tabs="true"]');
    if (!section) return;

    section.querySelectorAll<HTMLElement>('[data-players-view-dropdown]').forEach((root) => {
      const trigger = root.querySelector<HTMLButtonElement>('.players-view-trigger');
      const panel = root.querySelector<HTMLElement>('.players-view-panel');
      if (!trigger || !panel) return;

      function close(): void {
        if (panel.hidden) return;

        if (reducedMotion()) {
          panel.hidden = true;
          trigger.setAttribute('aria-expanded', 'false');
          return;
        }

        gsap.killTweensOf(panel);
        gsap.to(panel, {
          opacity: 0,
          y: -6,
          duration: 0.16,
          ease: 'power2.in',
          onComplete: () => {
            panel.hidden = true;
            trigger.setAttribute('aria-expanded', 'false');
            gsap.set(panel, { clearProps: 'all' });
          },
        });
      }

      function open(): void {
        if (!panel.hidden) return;

        trigger.setAttribute('aria-expanded', 'true');
        panel.hidden = false;

        if (reducedMotion()) return;

        gsap.killTweensOf(panel);
        gsap.fromTo(
          panel,
          { opacity: 0, y: -8, scale: 0.98 },
          {
            opacity: 1,
            y: 0,
            scale: 1,
            duration: 0.22,
            ease: 'power2.out',
            onComplete: () => {
              gsap.set(panel, { clearProps: 'opacity,transform' });
            },
          },
        );
      }

      function toggle(): void {
        if (panel.hidden) open();
        else close();
      }

      trigger.addEventListener('click', (e) => {
        e.stopPropagation();
        toggle();
      });

      root.querySelectorAll<HTMLButtonElement>('.players-view-option[data-view-tab]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const v = btn.dataset.viewTab;
          close();
          if (v === 'coaches' || v === 'players') {
            section.dispatchEvent(
              new CustomEvent('players:activate-tab', { bubbles: true, detail: { tab: v } }),
            );
          }
        });
      });

      document.addEventListener('click', (e) => {
        const t = e.target as Node;
        if (!root.contains(t) && !panel.hidden) close();
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !panel.hidden) {
          close();
          trigger.focus();
        }
      });
    });
  }

  function initPlayersSortDropdown(): void {
    document.querySelectorAll<HTMLElement>('[data-players-sort-root]').forEach((root) => {
      const trigger = root.querySelector<HTMLButtonElement>('.players-sort-trigger');
      const panel = root.querySelector<HTMLElement>('.players-sort-panel');
      if (!trigger || !panel) return;

      function close(): void {
        if (panel.hidden) return;

        if (reducedMotion()) {
          panel.hidden = true;
          trigger.setAttribute('aria-expanded', 'false');
          return;
        }

        gsap.killTweensOf(panel);
        gsap.to(panel, {
          opacity: 0,
          y: -6,
          duration: 0.16,
          ease: 'power2.in',
          onComplete: () => {
            panel.hidden = true;
            trigger.setAttribute('aria-expanded', 'false');
            gsap.set(panel, { clearProps: 'all' });
          },
        });
      }

      function open(): void {
        if (!panel.hidden) return;

        trigger.setAttribute('aria-expanded', 'true');
        panel.hidden = false;

        if (reducedMotion()) return;

        gsap.killTweensOf(panel);
        gsap.fromTo(
          panel,
          { opacity: 0, y: -8, scale: 0.98 },
          {
            opacity: 1,
            y: 0,
            scale: 1,
            duration: 0.22,
            ease: 'power2.out',
            onComplete: () => {
              gsap.set(panel, { clearProps: 'opacity,transform' });
            },
          },
        );
      }

      function toggle(): void {
        if (panel.hidden) open();
        else close();
      }

      trigger.addEventListener('click', (e) => {
        e.stopPropagation();
        toggle();
      });

      root.querySelectorAll<HTMLButtonElement>('[data-sort-value]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const v = btn.dataset.sortValue ?? 'default';
          const u = new URL(window.location.href);
          if (v === 'default') u.searchParams.delete('sort');
          else u.searchParams.set('sort', v);
          window.location.assign(u.pathname + u.search + u.hash);
        });
      });

      document.addEventListener('click', (e) => {
        const t = e.target as Node;
        if (!root.contains(t) && !panel.hidden) close();
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !panel.hidden) {
          close();
          trigger.focus();
        }
      });
    });
  }

  function initPlayersAnimations(): void {
    const section = document.querySelector<HTMLElement>('.players-section');
    if (!section || reducedMotion()) return;

    const label = section.querySelector<HTMLElement>('.ph-label');
    if (label) {
      trackingReveal(label, { trigger: label, start: 'top 88%', once: true });
    }

    const title = section.querySelector<HTMLElement>('.players-title');
    if (title) {
      const words = wrapWords(title);
      gsap.from(words, {
        yPercent: 115,
        duration: 0.85,
        stagger: 0.07,
        ease: 'power4.out',
        scrollTrigger: { trigger: title, start: 'top 82%', once: true },
      });
    }

    const subtitle = section.querySelector<HTMLElement>('.players-subtitle');
    if (subtitle) {
      const spans = splitWords(subtitle);
      gsap.from(spans, {
        y: 10,
        duration: 0.55,
        stagger: 0.03,
        ease: 'power2.out',
        scrollTrigger: { trigger: subtitle, start: 'top 88%', once: true },
      });
    }

    section.querySelectorAll<HTMLElement>('.players-section-title').forEach((subTitle) => {
      const words = wrapWords(subTitle);
      gsap.from(words, {
        yPercent: 100,
        duration: 0.65,
        stagger: 0.06,
        ease: 'power4.out',
        scrollTrigger: { trigger: subTitle, start: 'top 88%', once: true },
      });
    });

    const mobileToolbar = section.querySelector<HTMLElement>('[data-players-toolbar-animate]');
    if (mobileToolbar) {
      const rowKids = Array.from(mobileToolbar.children);
      gsap.from(rowKids, {
        opacity: 0,
        y: 12,
        duration: 0.45,
        stagger: 0.12,
        ease: 'power2.out',
        scrollTrigger: { trigger: mobileToolbar, start: 'top 88%', once: true },
      });
    }

    const mainToolbar = section.querySelector<HTMLElement>('.players-toolbar--desktop');
    if (mainToolbar) {
      const rowKids = Array.from(mainToolbar.children);
      gsap.from(rowKids, {
        opacity: 0,
        y: 12,
        duration: 0.45,
        stagger: 0.12,
        ease: 'power2.out',
        scrollTrigger: { trigger: mainToolbar, start: 'top 88%', once: true },
      });
    }

    section.querySelectorAll<HTMLElement>('.players-subsection-toolbar').forEach((subToolbar) => {
      const rowKids = Array.from(subToolbar.children);
      if (!rowKids.length) return;
      gsap.from(rowKids, {
        opacity: 0,
        y: 12,
        duration: 0.45,
        stagger: 0.12,
        ease: 'power2.out',
        scrollTrigger: { trigger: subToolbar, start: 'top 88%', once: true },
      });
    });

    const grids = section.querySelectorAll<HTMLElement>(
      '.players-subsection .players-grid, .players-tabpanel:not([hidden]) .players-grid',
    );
    grids.forEach((grid) => {
      const cards = grid.querySelectorAll<HTMLElement>('.card');
      if (!cards.length) return;
      gsap.from(cards, {
        y: 24,
        duration: 0.55,
        stagger: { each: 0.06, from: 'start' },
        ease: 'power3.out',
        scrollTrigger: {
          trigger: grid,
          start: 'top 88%',
          once: true,
        },
      });
    });

    requestAnimationFrame(() => {
      ScrollTrigger.refresh();
    });
  }

  function initPlayersSection(): void {
    initPlayersTabSwitch();
    initPlayersViewDropdown();
    initPlayersSortDropdown();
    initPlayersAnimations();

    const modalRoot = document.querySelector<HTMLElement>(
      '.players-section[data-player-detail-base]',
    );
    if (modalRoot) initPlayerModal(modalRoot);
  }

  document.addEventListener('astro:page-load', initPlayersSection);
</script>
