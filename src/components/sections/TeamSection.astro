---
import PortraitCard from '@/components/ui/PortraitCard.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import { useTranslations, type Lang } from '@/i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const TEAM_SIZE = 20;
const detailBase = lang === 'es' ? '/equipo' : '/en/team';

const slots = Array.from({ length: TEAM_SIZE }, (_, i) => {
  const n = i + 1;
  const slug = `miembro-${n}`;
  return { n, slug };
});

const teamPayloads: Record<
  string,
  { slug: string; name: string; subtitle: string; clubLogoSrc?: string }
> = {};
for (const s of slots) {
  teamPayloads[s.slug] = {
    slug: s.slug,
    name: t('team.placeholderName'),
    subtitle: t('team.placeholderRole'),
    clubLogoSrc: '/logo.svg',
  };
}
const teamPayloadsJson = JSON.stringify(teamPayloads);
---

<!-- Modal de ficha: variante "team" (lightbox apaisado, ver player-modal.ts) -->
<section
  class="team-section"
  aria-labelledby="team-heading"
  data-player-detail-base={detailBase}
  data-player-modal-close={t('a11y.close')}
  data-player-payloads={teamPayloadsJson}
  data-player-modal-variant="team"
>
  <div class="ph-section">
    <SectionHeader
      label={t('nav.team')}
      title={t('team.title')}
      subtitle={t('team.subtitle')}
      count={TEAM_SIZE}
      id="team-heading"
    />

    <ul class="team-grid">
      {slots.map(({ n, slug }) => (
        <li>
          <PortraitCard
            name={t('team.placeholderName')}
            subtitle={t('team.placeholderRole')}
            href={`${detailBase}/${slug}`}
            dataSlug={slug}
            ariaLabel={lang === 'en' ? `Team member ${n}` : `Miembro del equipo ${n}`}
          />
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .team-section {
    position: relative;
    background:
      radial-gradient(ellipse at 50% 0%, rgba(214, 178, 94, 0.02) 0%, transparent 50%),
      var(--color-ph-black);
  }


  .team-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .team-grid :global(.card) {
    opacity: 0;
  }

  .team-grid.cards-revealed :global(.card) {
    opacity: 1;
  }

  @media (min-width: 768px) {
    .team-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }
  }

  @media (min-width: 1024px) {
    .team-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 1.5rem;
    }
  }

  .team-grid > li {
    list-style: none;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import {
    reducedMotion,
    wrapWords,
    splitWords,
    trackingReveal,
  } from '@/scripts/ph-text-animations';
  import { initPlayerModal } from '@/scripts/player-modal';

  gsap.registerPlugin(ScrollTrigger);

  let teamScrollRefreshBound = false;

  function bindDebouncedScrollTriggerRefreshOnce(): void {
    if (teamScrollRefreshBound) return;
    teamScrollRefreshBound = true;
    let id: ReturnType<typeof setTimeout> | null = null;
    const schedule = (): void => {
      if (id !== null) window.clearTimeout(id);
      id = window.setTimeout(() => {
        id = null;
        ScrollTrigger.refresh();
      }, 150);
    };
    window.addEventListener('resize', schedule, { passive: true });
    window.addEventListener('orientationchange', schedule);
    window.visualViewport?.addEventListener('resize', schedule);
  }

  function initTeamAnimations(): void {
    const section = document.querySelector<HTMLElement>('.team-section');
    if (!section) return;
    if (reducedMotion()) {
      section.querySelectorAll<HTMLElement>('.team-grid').forEach((g) => g.classList.add('cards-revealed'));
      return;
    }

    const label = section.querySelector<HTMLElement>('.ph-label');
    if (label) {
      trackingReveal(label, { trigger: label, start: 'top 88%', once: true });
    }

    const count = section.querySelector<HTMLElement>('.section-header-count');
    if (count) {
      gsap.from(count, {
        opacity: 0,
        scale: 0.85,
        duration: 0.5,
        ease: 'back.out(1.5)',
        scrollTrigger: { trigger: count, start: 'top 88%', once: true },
      });
    }

    const title = section.querySelector<HTMLElement>('.section-header-title');
    if (title) {
      const words = wrapWords(title);
      gsap.from(words, {
        yPercent: 115,
        duration: 0.85,
        stagger: 0.07,
        ease: 'power4.out',
        scrollTrigger: { trigger: title, start: 'top 82%', once: true },
      });
    }

    const subtitle = section.querySelector<HTMLElement>('.section-header-subtitle');
    if (subtitle) {
      const spans = splitWords(subtitle);
      gsap.from(spans, {
        opacity: 0,
        filter: 'blur(6px)',
        y: 6,
        duration: 0.6,
        stagger: 0.03,
        ease: 'power2.out',
        scrollTrigger: { trigger: subtitle, start: 'top 88%', once: true },
      });
    }

    const grid = section.querySelector<HTMLElement>('.team-grid');
    const cards = grid?.querySelectorAll<HTMLElement>('.card');
    if (grid && cards?.length) {
      gsap.fromTo(
        cards,
        { opacity: 0, y: 24 },
        {
          opacity: 1,
          y: 0,
          duration: 0.55,
          stagger: { each: 0.06, from: 'start' },
          ease: 'power3.out',
          scrollTrigger: {
            trigger: grid,
            start: 'top 88%',
            once: true,
          },
          onComplete: () => {
            grid.classList.add('cards-revealed');
            gsap.set(cards, { clearProps: 'opacity,transform' });
          },
        },
      );
    }

    requestAnimationFrame(() => {
      ScrollTrigger.refresh();
    });

    window.setTimeout(() => {
      document.querySelectorAll<HTMLElement>('.team-grid:not(.cards-revealed)').forEach((grid) => {
        const cardEls = grid.querySelectorAll<HTMLElement>('.card');
        if (!cardEls.length) return;
        grid.classList.add('cards-revealed');
        gsap.set(cardEls, { clearProps: 'opacity,transform' });
      });
    }, 2200);
  }

  function initTeamSection(): void {
    bindDebouncedScrollTriggerRefreshOnce();
    initTeamAnimations();

    const modalRoot = document.querySelector<HTMLElement>(
      '.team-section[data-player-detail-base]',
    );
    if (modalRoot) initPlayerModal(modalRoot);
  }

  document.addEventListener('astro:page-load', initTeamSection);
</script>
