---
import PortraitCard from '@/components/ui/PortraitCard.astro';
import { useTranslations, type Lang } from '@/i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const TEAM_SIZE = 20;
const slots = Array.from({ length: TEAM_SIZE }, (_, i) => i + 1);
---

<section class="team-section" aria-labelledby="team-heading">
  <div class="ph-section">
    <header class="team-header">
      <div class="team-header-top">
        <span class="ph-label">{t('nav.team')}</span>
        <span class="team-count">{TEAM_SIZE}</span>
      </div>
      <div class="ph-divider mt-4"></div>
      <h1 id="team-heading" class="team-title">
        {t('team.title')}
      </h1>
      <p class="team-subtitle">{t('team.subtitle')}</p>
    </header>

    <ul class="team-grid">
      {slots.map((n) => (
        <li>
          <PortraitCard
            name={t('team.placeholderName')}
            subtitle={t('team.placeholderRole')}
            ariaLabel={lang === 'en' ? `Team member ${n}` : `Miembro del equipo ${n}`}
          />
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .team-section {
    position: relative;
    background:
      radial-gradient(ellipse at 50% 0%, rgba(214, 178, 94, 0.02) 0%, transparent 50%),
      var(--ph-black);
  }

  .team-header {
    margin-bottom: 3rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--ph-white-10);
  }

  @media (min-width: 1024px) {
    .team-header {
      margin-bottom: 4rem;
      padding-bottom: 3rem;
    }
  }

  .team-header-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .team-count {
    font-family: var(--ph-font-display);
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--ph-white-60);
    padding: 0.125rem 0.5rem;
    border: 1px solid var(--ph-white-10);
    border-radius: var(--ph-radius);
    letter-spacing: 0.04em;
  }

  .team-title {
    margin-top: 2rem;
    font-family: var(--ph-font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--ph-white);
  }

  .team-subtitle {
    margin-top: 1rem;
    font-size: 1.0625rem;
    color: var(--ph-white-60);
    max-width: 40rem;
    line-height: 1.6;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  @media (min-width: 768px) {
    .team-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }
  }

  @media (min-width: 1024px) {
    .team-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 1.5rem;
    }
  }

  .team-grid > li {
    list-style: none;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import {
    reducedMotion,
    wrapWords,
    splitWords,
    trackingReveal,
  } from '@/scripts/ph-text-animations';

  function initTeamAnimations(): void {
    const section = document.querySelector<HTMLElement>('.team-section');
    if (!section || reducedMotion()) return;

    const label = section.querySelector<HTMLElement>('.ph-label');
    if (label) {
      trackingReveal(label, { trigger: label, start: 'top 88%', once: true });
    }

    const count = section.querySelector<HTMLElement>('.team-count');
    if (count) {
      gsap.from(count, {
        opacity: 0,
        scale: 0.85,
        duration: 0.5,
        ease: 'back.out(1.5)',
        scrollTrigger: { trigger: count, start: 'top 88%', once: true },
      });
    }

    const title = section.querySelector<HTMLElement>('.team-title');
    if (title) {
      const words = wrapWords(title);
      gsap.from(words, {
        yPercent: 115,
        duration: 0.85,
        stagger: 0.07,
        ease: 'power4.out',
        scrollTrigger: { trigger: title, start: 'top 82%', once: true },
      });
    }

    const subtitle = section.querySelector<HTMLElement>('.team-subtitle');
    if (subtitle) {
      const spans = splitWords(subtitle);
      gsap.from(spans, {
        opacity: 0,
        filter: 'blur(6px)',
        y: 6,
        duration: 0.6,
        stagger: 0.03,
        ease: 'power2.out',
        scrollTrigger: { trigger: subtitle, start: 'top 88%', once: true },
      });
    }

    const cards = section.querySelectorAll<HTMLElement>('.card');
    if (cards.length) {
      gsap.from(cards, {
        opacity: 0,
        y: 24,
        duration: 0.55,
        stagger: { each: 0.06, from: 'start' },
        ease: 'power3.out',
        scrollTrigger: {
          trigger: '.team-grid',
          start: 'top 88%',
          once: true,
        },
      });
    }
  }

  document.addEventListener('astro:page-load', initTeamAnimations);
</script>
