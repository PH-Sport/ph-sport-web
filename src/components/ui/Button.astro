---
type BaseProps = {
  href?: string;
  variant?: 'primary' | 'secondary';
  class?: string;
  type?: 'button' | 'submit' | 'reset';
};

type Props = BaseProps &
  (
    | astroHTML.JSX.AnchorHTMLAttributes
    | astroHTML.JSX.ButtonHTMLAttributes
  );

const {
  href,
  variant = 'primary',
  class: className = '',
  type = 'button',
  ...rest
} = Astro.props;
---

{href ? (
  <a href={href} class:list={['btn', `btn--${variant}`, className]} {...rest}>
    <span class="btn-label"><slot /></span>
  </a>
) : (
  <button type={type} class:list={['btn', `btn--${variant}`, className]} {...rest}>
    <span class="btn-label"><slot /></span>
  </button>
)}

<style>
  .btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 2rem;
    font-family: var(--font-display);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    overflow: hidden;
    border: 1px solid;
    border-radius: var(--radius-sm);
    cursor: pointer;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
    transition:
      border-color var(--ph-duration) var(--ease-ph),
      color var(--ph-duration) var(--ease-ph);
  }

  .btn::before {
    content: '';
    position: absolute;
    inset: 0;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--ph-duration) var(--ease-ph);
    pointer-events: none;
  }

  @media (hover: hover) {
    .btn:hover::before {
      transform: scaleX(1);
    }
  }

  .btn-label {
    position: relative;
    z-index: 1;
    transition: color var(--ph-duration) var(--ease-ph);
  }

  /* Primary — gold fill slide-in */
  .btn--primary {
    border-color: var(--color-ph-gold);
    color: var(--color-ph-gold);
  }

  .btn--primary::before {
    background: var(--color-ph-gold);
  }

  @media (hover: hover) {
    .btn--primary:hover {
      color: var(--color-ph-black);
    }
  }

  /* Secondary — ghost, subtle fill */
  .btn--secondary {
    border-color: var(--color-ph-white-20);
    color: var(--color-ph-white-60);
  }

  .btn--secondary::before {
    background: var(--color-ph-white-10);
  }

  @media (hover: hover) {
    .btn--secondary:hover {
      border-color: var(--color-ph-white-60);
      color: var(--color-ph-white);
    }
  }
</style>
