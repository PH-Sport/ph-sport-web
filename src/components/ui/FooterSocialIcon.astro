---
import type { SocialId } from '@/lib/social';

interface Props {
  id: SocialId;
}

const { id } = Astro.props;
---

{
  id === 'instagram' && (
    <svg class="footer-social-svg" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
      <path d="M7.8 2h8.4C19.4 2 22 4.6 22 7.8v8.4a5.8 5.8 0 0 1-5.8 5.8H7.8C4.6 22 2 19.4 2 16.2V7.8A5.8 5.8 0 0 1 7.8 2m-.2 2A3.6 3.6 0 0 0 4 7.6v8.8A3.6 3.6 0 0 0 7.6 20h8.8A3.6 3.6 0 0 0 20 16.4V7.6A3.6 3.6 0 0 0 16.4 4H7.6m9.65 1.5a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5M12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10m0 2a3 3 0 1 0 .001 6A3 3 0 0 0 12 9z" />
    </svg>
  )
}
{
  id === 'linkedin' && (
    <svg class="footer-social-svg" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
      <path d="M6.94 6.5a1.49 1.49 0 1 1-.002 2.982A1.49 1.49 0 0 1 6.94 6.5zM4.5 20.5h4.88V9.75H4.5V20.5zM14.62 9.75c-2.1 0-3.44 1.16-3.5 2.86h-.05v-2.86H7.5V20.5h4.62v-5.59c0-1.94.37-3.81 2.76-3.81 2.36 0 2.38 2.2 2.38 3.92V20.5H22v-6.84c0-3.88-.84-6.91-5.38-6.91z" />
    </svg>
  )
}
{
  id === 'x' && (
    <svg class="footer-social-svg" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
      <path d="M13.904 10.44 20.5 2.5h-1.56l-5.72 6.62L8.74 2.5H3.5l6.94 10.1L3.5 21.5h1.56l6.05-7.02 4.83 7.02h5.24l-7.16-10.1zM11.7 13.09l-.7-.99-5.6-7.95h2.42l4.53 6.45.7.99 5.88 8.37h-2.42l-4.8-6.87z" />
    </svg>
  )
}
