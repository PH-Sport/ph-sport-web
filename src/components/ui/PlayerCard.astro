---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { Lang } from '@/i18n/utils';

interface Props {
  name: string;
  position: { es: string; en: string };
  club: { name: string; country?: string };
  photo: ImageMetadata;
  slug: string;
  lang: Lang;
}

const { name, position, club, photo, slug, lang } = Astro.props;
---

<a href="#" data-slug={slug} class="card">
  <Image
    src={photo}
    alt={`${name} — ${position[lang]}`}
    class="card-img"
    loading="lazy"
    widths={[320, 480, 640]}
    sizes="(max-width: 768px) 50vw, (max-width: 1024px) 33vw, 25vw"
  />

  <div class="card-overlay">
    <p class="card-name">{name}</p>
    <p class="card-pos">{position[lang]}</p>
    <p class="card-club">{club.name}</p>
  </div>
</a>

<style>
  .card {
    position: relative;
    display: block;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    border-radius: var(--ph-radius-card);
    border: 1px solid var(--ph-white-10);
    background: var(--ph-white-10);
    transition:
      border-color 500ms var(--ph-ease),
      box-shadow 500ms var(--ph-ease);
  }

  /* Gold accent line — slides in from left on hover */
  .card::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--ph-gold), var(--ph-gold-muted));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 500ms var(--ph-ease);
    z-index: 3;
    border-radius: var(--ph-radius-card) var(--ph-radius-card) 0 0;
  }

  .card:hover {
    border-color: var(--ph-white-20);
    box-shadow: 0 4px 32px rgba(214, 178, 94, 0.1);
  }

  .card:hover::after {
    transform: scaleX(1);
  }

  .card-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 600ms var(--ph-ease);
  }

  .card:hover .card-img {
    transform: scale(1.06);
  }

  .card-overlay {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    padding: 5rem 1.25rem 1.25rem;
    background: linear-gradient(
      to top,
      rgba(13, 15, 18, 0.95) 0%,
      rgba(13, 15, 18, 0.5) 55%,
      transparent 100%
    );
    z-index: 2;
  }

  .card-name {
    font-family: var(--ph-font-display);
    font-weight: 700;
    font-size: 1rem;
    color: var(--ph-white);
    letter-spacing: -0.01em;
  }

  .card-pos {
    font-family: var(--ph-font-body);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ph-gold);
    margin-top: 0.25rem;
  }

  .card-club {
    font-size: 0.8125rem;
    color: var(--ph-white-60);
    margin-top: 0.125rem;
  }
</style>
