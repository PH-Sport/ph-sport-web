---
import { useTranslations, type Lang } from '@/i18n/utils';
import type { SortMode } from '@/lib/sortRoster';

interface Props {
  lang: Lang;
  sortMode: SortMode;
  /** Sufijo para ids únicos si hay más de un control de orden en la página (p. ej. `-sheet`). */
  idSuffix?: string;
}

const { lang, sortMode, idSuffix = '' } = Astro.props;
const t = useTranslations(lang);

const triggerId = `players-sort-trigger${idSuffix}`;
const listboxId = `players-sort-listbox${idSuffix}`;

const labelCurrent =
  sortMode === 'az'
    ? t('players.sort.option.az')
    : sortMode === 'za'
      ? t('players.sort.option.za')
      : t('players.sort.option.default');
---

<div class="players-sort-root" data-players-sort-root>
  <div class="players-sort-dropdown">
    <button
      type="button"
      class="players-sort-trigger ph-ui-btn ph-ui-btn--secondary"
      id={triggerId}
      aria-haspopup="listbox"
      aria-expanded="false"
      aria-controls={listboxId}
      title={`${t('players.sort.aria')}: ${labelCurrent}`}
      aria-label={`${t('players.sort.aria')}: ${labelCurrent}`}
    >
      <span class="players-sort-label">{t('players.sort.label')}</span>
      <span class="players-sort-icon" aria-hidden="true">
        <svg
          class="players-sort-icon-svg"
          width="12"
          height="12"
          viewBox="0 0 12 12"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <g class="players-sort-chevron-g">
            <path
              d="M3 4.5L6 7.5L9 4.5"
              stroke="currentColor"
              stroke-width="1.15"
              stroke-linecap="round"
              stroke-linejoin="round"
              opacity="0.72"
            />
          </g>
        </svg>
      </span>
    </button>
    <div
      id={listboxId}
      class="players-sort-panel"
      role="listbox"
      aria-labelledby={triggerId}
      hidden
    >
      <button
        type="button"
        class="players-sort-option"
        role="option"
        data-sort-value="default"
        aria-selected={sortMode === 'default'}
      >
        {t('players.sort.option.default')}
      </button>
      <button
        type="button"
        class="players-sort-option"
        role="option"
        data-sort-value="az"
        aria-selected={sortMode === 'az'}
      >
        {t('players.sort.option.az')}
      </button>
      <button
        type="button"
        class="players-sort-option"
        role="option"
        data-sort-value="za"
        aria-selected={sortMode === 'za'}
      >
        {t('players.sort.option.za')}
      </button>
    </div>
  </div>
</div>

<style>
  .players-sort-root {
    display: inline-block;
    width: auto;
    max-width: 100%;
    min-width: 0;
  }

  .players-sort-dropdown {
    position: relative;
    display: inline-block;
    width: auto;
    min-width: 0;
  }

  .players-sort-trigger {
    width: auto;
    max-width: 100%;
    justify-content: center;
    gap: 0.35rem;
    min-height: 2.35rem;
    padding: 0.35rem 0.55rem;
    text-align: left;
  }

  @media (min-width: 640px) {
    .players-sort-trigger {
      min-height: 2.75rem;
      padding: 0.5rem 0.75rem;
    }
  }

  .players-sort-label {
    flex: 0 1 auto;
    min-width: 0;
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: inherit;
    display: inline-flex;
    align-items: center;
  }

  .players-sort-trigger[aria-expanded='true'] {
    border-color: rgba(214, 178, 94, 0.35);
    color: var(--color-ph-white);
    background: rgba(214, 178, 94, 0.1);
  }

  .players-sort-trigger[aria-expanded='true']::before {
    transform: scaleX(0);
  }

  .players-sort-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    line-height: 0;
  }

  .players-sort-icon-svg {
    display: block;
    flex-shrink: 0;
  }

  .players-sort-chevron-g {
    transform-box: fill-box;
    transform-origin: center;
    transition: transform 0.2s var(--ease-ph);
  }

  .players-sort-trigger[aria-expanded='true'] .players-sort-chevron-g {
    transform: rotate(180deg);
  }

  .players-sort-panel {
    position: absolute;
    z-index: 100;
    right: 0;
    top: calc(100% + 0.35rem);
    min-width: 10rem;
    padding: 0.25rem;
    border: 1px solid var(--color-ph-white-10);
    border-radius: var(--radius-sm);
    background: rgba(13, 15, 18, 0.98);
    box-shadow: 0 10px 32px rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(8px);
  }

  .players-sort-panel[hidden] {
    display: none !important;
  }

  .players-sort-option {
    display: block;
    width: 100%;
    text-align: left;
    padding: 0.45rem 0.72rem;
    margin: 0;
    border: none;
    border-radius: calc(var(--radius-sm) - 2px);
    cursor: pointer;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-ph-white-60);
    background: transparent;
    transition:
      color 0.2s var(--ease-ph),
      background-color 0.2s var(--ease-ph);
  }

  .players-sort-option:hover {
    color: var(--color-ph-white);
    background: rgba(255, 255, 255, 0.06);
  }

  .players-sort-option:focus-visible {
    outline: 2px solid var(--color-ph-gold);
    outline-offset: 0;
  }

  .players-sort-option[aria-selected='true'] {
    color: var(--color-ph-white);
    background: rgba(214, 178, 94, 0.12);
    box-shadow: inset 0 0 0 1px rgba(214, 178, 94, 0.3);
  }
</style>
