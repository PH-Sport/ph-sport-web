---
import { useTranslations, type Lang } from '@/i18n/utils';

interface Props {
  lang: Lang;
  showCoachesPanelFirst: boolean;
}

const { lang, showCoachesPanelFirst } = Astro.props;
const t = useTranslations(lang);

const labelPlayers = t('players.subsection.players');
const labelCoaches = t('players.subsection.coaches');
const currentLabel = showCoachesPanelFirst ? labelCoaches : labelPlayers;
const ariaLabel = `${t('players.tabs.aria')}: ${currentLabel}`;
---

<div class="players-view-root" data-players-view-dropdown>
  <div class="players-view-dropdown">
    <button
      type="button"
      class="players-view-trigger ph-ui-btn ph-ui-btn--secondary"
      id="players-view-trigger-mobile"
      aria-haspopup="listbox"
      aria-expanded="false"
      aria-controls="players-view-listbox-mobile"
      aria-label={ariaLabel}
    >
      <span class="players-view-trigger-text">
        <span id="players-view-trigger-mobile-label" class="players-view-trigger-label">{currentLabel}</span>
      </span>
      <span class="players-view-icon" aria-hidden="true">
        <svg
          class="players-view-icon-svg"
          width="23"
          height="16"
          viewBox="0 0 20 14"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <g class="players-view-chevron-g">
            <path
              d="M14.5 5.5L17 8l2.5-2.5"
              stroke="currentColor"
              stroke-width="1.15"
              stroke-linecap="round"
              stroke-linejoin="round"
              opacity="0.72"
            />
          </g>
        </svg>
      </span>
    </button>
    <div
      id="players-view-listbox-mobile"
      class="players-view-panel"
      role="listbox"
      aria-labelledby="players-view-trigger-mobile"
      hidden
    >
      <button
        type="button"
        class="players-view-option"
        role="option"
        data-view-tab="players"
        aria-selected={!showCoachesPanelFirst}
      >
        <span class="players-view-option-label">{labelPlayers}</span>
      </button>
      <button
        type="button"
        class="players-view-option"
        role="option"
        data-view-tab="coaches"
        aria-selected={showCoachesPanelFirst}
      >
        <span class="players-view-option-label">{labelCoaches}</span>
      </button>
    </div>
  </div>
</div>

<style>
  .players-view-root {
    display: block;
    width: 100%;
    max-width: 100%;
    min-width: 0;
  }

  .players-view-dropdown {
    position: relative;
    display: block;
    width: 100%;
    min-width: 0;
  }

  .players-view-trigger {
    width: 100%;
    max-width: 100%;
    justify-content: space-between;
    gap: 0.35rem;
    min-height: 2.35rem;
    padding: 0.35rem 0.55rem;
    text-align: left;
  }

  .players-view-trigger-text {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    min-width: 0;
    flex: 1 1 auto;
  }

  .players-view-trigger-label {
    flex: 1 1 auto;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-family: var(--font-display);
    font-size: 0.6875rem;
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: inherit;
  }

  .players-view-trigger[aria-expanded='true'] {
    border-color: rgba(214, 178, 94, 0.35);
    color: var(--color-ph-white);
    background: rgba(214, 178, 94, 0.1);
  }

  .players-view-trigger[aria-expanded='true']::before {
    transform: scaleX(0);
  }

  .players-view-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    line-height: 0;
  }

  .players-view-icon-svg {
    display: block;
    flex-shrink: 0;
  }

  .players-view-chevron-g {
    transform-box: fill-box;
    transform-origin: center;
    transition: transform 0.2s var(--ease-ph);
  }

  .players-view-trigger[aria-expanded='true'] .players-view-chevron-g {
    transform: rotate(180deg);
  }

  .players-view-panel {
    position: absolute;
    z-index: 100;
    left: 0;
    right: 0;
    top: calc(100% + 0.35rem);
    min-width: 10rem;
    padding: 0.25rem;
    border: 1px solid var(--color-ph-white-10);
    border-radius: var(--radius-sm);
    background: rgba(13, 15, 18, 0.98);
    box-shadow: 0 10px 32px rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(8px);
  }

  .players-view-panel[hidden] {
    display: none !important;
  }

  .players-view-option {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 0.5rem;
    width: 100%;
    text-align: left;
    padding: 0.45rem 0.72rem;
    margin: 0;
    border: none;
    border-radius: calc(var(--radius-sm) - 2px);
    cursor: pointer;
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-ph-white-60);
    background: transparent;
    transition:
      color 0.2s var(--ease-ph),
      background-color 0.2s var(--ease-ph);
  }

  .players-view-option-label {
    flex: 1 1 auto;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .players-view-option:hover {
    color: var(--color-ph-white);
    background: rgba(255, 255, 255, 0.06);
  }

  .players-view-option:focus-visible {
    outline: 2px solid var(--color-ph-gold);
    outline-offset: 0;
  }

  .players-view-option[aria-selected='true'] {
    color: var(--color-ph-white);
    background: rgba(214, 178, 94, 0.12);
    box-shadow: inset 0 0 0 1px rgba(214, 178, 94, 0.3);
  }
</style>
