---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
/** `?url` fuerza una URL de cadena válida para `<img src>` (el import por defecto del SVG suele fallar en runtime). */
import placeholderSrc from '@/assets/images/players/avatar-placeholder.svg?url';
import 'flag-icons/css/flag-icons.min.css';

interface Props {
  name: string;
  /** Línea dorada (club, cargo, etc.), ya localizada si aplica */
  subtitle: string;
  photo?: ImageMetadata;
  /** Si se omite, la card no es un enlace (p. ej. equipo interno) */
  href?: string;
  dataSlug?: string;
  /** Distingue miembros con el mismo nombre visible (p. ej. placeholders) */
  ariaLabel?: string;
  /** Códigos ISO 3166-1 alpha-2 para banderas de selección */
  nationalTeamCodes?: string[];
  /** Texto para lectores de pantalla (nombres de país localizados) */
  nationalTeamAriaLabel?: string;
}

const {
  name,
  subtitle,
  photo,
  href,
  dataSlug,
  ariaLabel,
  nationalTeamCodes = [],
  nationalTeamAriaLabel,
} = Astro.props;
const alt = `${name} — ${subtitle}`;
const cardTitle = alt;
const showFlags = nationalTeamCodes.length > 0 && nationalTeamAriaLabel;
---

{
  href !== undefined ? (
    <a href={href} class="card" data-slug={dataSlug} title={cardTitle}>
      {photo ? (
        <Image
          src={photo}
          alt={alt}
          class="card-img"
          loading="lazy"
          widths={[320, 480, 640]}
          sizes="(max-width: 768px) 50vw, (max-width: 1024px) 33vw, 25vw"
        />
      ) : (
        <img
          src={placeholderSrc}
          alt={alt}
          class="card-img card-img--placeholder"
          width={480}
          height={640}
          loading="lazy"
          decoding="async"
        />
      )}
      {showFlags ? (
        <div class="card-flags" role="group" aria-label={nationalTeamAriaLabel}>
          {nationalTeamCodes.map((code) => (
            <span class={`fi fi-${code.toLowerCase()}`} aria-hidden="true"></span>
          ))}
        </div>
      ) : null}
      <div class="card-overlay">
        <p class="card-name">{name}</p>
        <p class="card-subtitle">{subtitle}</p>
      </div>
    </a>
  ) : (
    <article class="card" aria-label={ariaLabel ?? cardTitle} title={cardTitle}>
      {photo ? (
        <Image
          src={photo}
          alt={alt}
          class="card-img"
          loading="lazy"
          widths={[320, 480, 640]}
          sizes="(max-width: 768px) 50vw, (max-width: 1024px) 33vw, 25vw"
        />
      ) : (
        <img
          src={placeholderSrc}
          alt={alt}
          class="card-img card-img--placeholder"
          width={480}
          height={640}
          loading="lazy"
          decoding="async"
        />
      )}
      {showFlags ? (
        <div class="card-flags" role="group" aria-label={nationalTeamAriaLabel}>
          {nationalTeamCodes.map((code) => (
            <span class={`fi fi-${code.toLowerCase()}`} aria-hidden="true"></span>
          ))}
        </div>
      ) : null}
      <div class="card-overlay">
        <p class="card-name">{name}</p>
        <p class="card-subtitle">{subtitle}</p>
      </div>
    </article>
  )
}

<style>
  .card {
    position: relative;
    display: block;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    border-radius: var(--radius-md);
    border: 1px solid var(--ph-glass-border);
    background: var(--ph-glass-bg);
    backdrop-filter: blur(var(--ph-glass-blur));
    -webkit-backdrop-filter: blur(var(--ph-glass-blur));
    /* iOS: evita retardo de doble toque para zoom y mejora respuesta del primer tap en enlaces */
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
    transition:
      border-color 500ms var(--ease-ph),
      box-shadow 500ms var(--ease-ph);
  }

  .card::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--color-ph-gold), var(--color-ph-gold-muted));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 500ms var(--ease-ph);
    z-index: 3;
    border-radius: var(--radius-md) var(--radius-md) 0 0;
  }

  /* Solo ratón/trackpad: en iPhone el :hover “pegajoso” hace que el 1er toque active hover y el 2º ejecute la acción */
  @media (hover: hover) and (pointer: fine) {
    .card:hover {
      border-color: var(--color-ph-white-20);
      box-shadow: 0 4px 32px rgba(214, 178, 94, 0.1);
    }

    .card:hover::after {
      transform: scaleX(1);
    }

    .card:hover .card-img {
      transform: scale(1.06);
    }
  }

  .card-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 600ms var(--ease-ph);
  }

  .card-img--placeholder {
    object-fit: cover;
    object-position: center top;
    background: var(--color-ph-black);
  }

  .card-flags {
    position: absolute;
    bottom: 0.625rem;
    right: 0.625rem;
    z-index: 4;
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.35rem;
    max-width: calc(100% - 1.25rem);
    pointer-events: none;
  }

  .card-flags :global(.fi) {
    width: 1.35rem;
    height: auto;
    border-radius: 2px;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.35);
  }

  .card-overlay {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    padding: 4rem 1.25rem 1.25rem;
    background: linear-gradient(
      to top,
      rgba(13, 15, 18, 0.95) 0%,
      rgba(13, 15, 18, 0.5) 55%,
      transparent 100%
    );
    z-index: 2;
  }

  .card-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    color: var(--color-ph-white);
    letter-spacing: -0.01em;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow: hidden;
    word-break: break-word;
  }

  .card-subtitle {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ph-gold);
    margin-top: 0.35rem;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow: hidden;
    word-break: break-word;
  }

  @media (max-width: 767px) {
    .card-subtitle {
      font-size: 0.625rem;
    }
  }
</style>
