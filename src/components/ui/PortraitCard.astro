---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  name: string;
  /** Línea dorada (club, cargo, etc.), ya localizada si aplica */
  subtitle: string;
  photo?: ImageMetadata;
  /** Si se omite, la card no es un enlace (p. ej. equipo interno) */
  href?: string;
  dataSlug?: string;
  /** Distingue miembros con el mismo nombre visible (p. ej. placeholders) */
  ariaLabel?: string;
}

const { name, subtitle, photo, href, dataSlug, ariaLabel } = Astro.props;
const alt = `${name} — ${subtitle}`;
---

{
  href !== undefined ? (
    <a href={href} class="card" data-slug={dataSlug}>
      {photo ? (
        <Image
          src={photo}
          alt={alt}
          class="card-img"
          loading="lazy"
          widths={[320, 480, 640]}
          sizes="(max-width: 768px) 50vw, (max-width: 1024px) 33vw, 25vw"
        />
      ) : (
        <div class="card-img card-img--placeholder" aria-hidden="true"></div>
      )}
      <div class="card-overlay">
        <p class="card-name">{name}</p>
        <p class="card-subtitle">{subtitle}</p>
      </div>
    </a>
  ) : (
    <article class="card" aria-label={ariaLabel}>
      {photo ? (
        <Image
          src={photo}
          alt={alt}
          class="card-img"
          loading="lazy"
          widths={[320, 480, 640]}
          sizes="(max-width: 768px) 50vw, (max-width: 1024px) 33vw, 25vw"
        />
      ) : (
        <div class="card-img card-img--placeholder" aria-hidden="true"></div>
      )}
      <div class="card-overlay">
        <p class="card-name">{name}</p>
        <p class="card-subtitle">{subtitle}</p>
      </div>
    </article>
  )
}

<style>
  .card {
    position: relative;
    display: block;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    border-radius: var(--ph-radius-card);
    border: 1px solid var(--ph-white-10);
    background: var(--ph-white-10);
    transition:
      border-color 500ms var(--ph-ease),
      box-shadow 500ms var(--ph-ease);
  }

  .card::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--ph-gold), var(--ph-gold-muted));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 500ms var(--ph-ease);
    z-index: 3;
    border-radius: var(--ph-radius-card) var(--ph-radius-card) 0 0;
  }

  .card:hover {
    border-color: var(--ph-white-20);
    box-shadow: 0 4px 32px rgba(214, 178, 94, 0.1);
  }

  .card:hover::after {
    transform: scaleX(1);
  }

  .card-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 600ms var(--ph-ease);
  }

  .card-img--placeholder {
    background: linear-gradient(
      145deg,
      var(--ph-white-10) 0%,
      rgba(214, 178, 94, 0.08) 50%,
      var(--ph-white-10) 100%
    );
  }

  .card:hover .card-img {
    transform: scale(1.06);
  }

  .card-overlay {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    padding: 4rem 1.25rem 1.25rem;
    background: linear-gradient(
      to top,
      rgba(13, 15, 18, 0.95) 0%,
      rgba(13, 15, 18, 0.5) 55%,
      transparent 100%
    );
    z-index: 2;
  }

  .card-name {
    font-family: var(--ph-font-display);
    font-weight: 700;
    font-size: 1rem;
    color: var(--ph-white);
    letter-spacing: -0.01em;
  }

  .card-subtitle {
    font-family: var(--ph-font-body);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ph-gold);
    margin-top: 0.35rem;
  }
</style>
