---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '@/components/layout/BaseLayout.astro';
import PlayerDetailView from '@/components/players/PlayerDetailView.astro';
import {
  buildPlayerDetailPayloadsForLang,
  getAllRosterEntries,
  getPlayersCollectionBySlug,
  type PlayerDetailPayload,
} from '@/lib/playerDetail';
import { getPlayerPhotoBySlug } from '@/lib/playerPhotos';
import { useTranslations, type Lang } from '@/i18n/utils';
import { SITE_URL } from '@/lib/constants';

interface Props {
  payload: PlayerDetailPayload;
  collectionEntry: CollectionEntry<'players'> | null;
}

export async function getStaticPaths() {
  const bySlug = await getPlayersCollectionBySlug();
  const entries = getAllRosterEntries();
  const payloads = await buildPlayerDetailPayloadsForLang('en');
  return entries.map(({ slug }) => ({
    params: { slug },
    props: {
      payload: payloads[slug]!,
      collectionEntry: bySlug.get(slug) ?? null,
    },
  }));
}

const lang: Lang = 'en';
const t = useTranslations(lang);
const { slug } = Astro.params;
const { payload, collectionEntry } = Astro.props;

const assetPhoto = getPlayerPhotoBySlug(slug!);
const photo = assetPhoto ?? undefined;

const title = `${payload.name} — ${t('site.name')}`;
const description = payload.subtitle ? `${payload.name} · ${payload.subtitle}` : payload.name;
---

<BaseLayout
  title={title}
  description={description}
  lang={lang}
  canonical={`${SITE_URL}/en/players/${slug}`}
>
  <div class="ph-section player-detail-page">
    <PlayerDetailView
      lang={lang}
      payload={payload}
      photo={photo}
      collectionEntry={collectionEntry}
      backHref="/en/players/"
      backLabel={t('players.back')}
      bioEmptyLabel={t('players.detail.bioEmpty')}
    />
  </div>
</BaseLayout>
