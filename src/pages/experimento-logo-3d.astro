---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import { SITE_URL } from '@/lib/constants';

---

<BaseLayout
  title="Experimento Logo 3D | PH Sport"
  description="Página de prueba interna para animación de scroll del logo 3D."
  lang="es"
  canonical={`${SITE_URL}/experimento-logo-3d`}
  hasHero
  noIndex
>
  <section class="cine-exp" data-cine-exp data-logo3d-scroll-experiment>
    <div class="cine-exp__track" data-logo3d-scroll-track>
      <div class="cine-exp__sticky" data-cine-sticky>
        <div class="cine-exp__canvas" data-logo3d-scroll-root></div>

        <div class="cine-exp__vignette" data-cine-vignette aria-hidden="true"></div>
        <div class="cine-exp__wash" aria-hidden="true"></div>
        <span class="cine-exp__watermark" data-cine-watermark aria-hidden="true">PH</span>

        <!-- Acto I: apertura (tono sitio) -->
        <div class="cine-exp__act cine-exp__act--intro" data-cine-act="intro">
          <div class="cine-glass">
            <div class="cine-glass__body cine-intro__panel">
              <p class="cine-intro__tagline" data-cine-intro-tagline>Now. Next. Forever Football.</p>
              <h1 class="cine-intro__claim">
                <span class="cine-intro__word">Donde</span>
                <span class="cine-intro__word">el</span>
                <span class="cine-intro__word">talento</span>
                <span class="cine-intro__word">construye</span>
                <span class="cine-intro__word">su</span>
                <span class="cine-intro__word">legado</span>
              </h1>
            </div>
          </div>
        </div>

        <!-- Acto II: pilares Now / Next / Forever -->
        <div class="cine-exp__act cine-exp__act--pillars" data-cine-act="pillars">
          <div class="cine-glass">
            <div class="cine-glass__body cine-pillars__panel">
              <p class="cine-pillars__eyebrow" data-cine-pillars-eyebrow>Presente, futuro y legado</p>
              <div class="cine-pillars__stack">
                <div class="cine-pillars__item" data-cine-pillar>
                  <h2 class="cine-pillar__title" data-cine-pillar-title>Now.</h2>
                  <p class="cine-pillar__body" data-cine-pillar-body>
                    Gestionamos el día a día de cada jugador con atención personalizada. Contratos, imagen,
                    rendimiento.
                  </p>
                </div>
                <div class="cine-pillars__item" data-cine-pillar>
                  <h2 class="cine-pillar__title" data-cine-pillar-title>Next.</h2>
                  <p class="cine-pillar__body" data-cine-pillar-body>
                    Planificamos la carrera a medio y largo plazo. Cada fichaje es un paso estratégico, no una
                    oportunidad aislada.
                  </p>
                </div>
                <div class="cine-pillars__item" data-cine-pillar>
                  <h2 class="cine-pillar__title" data-cine-pillar-title>Forever Football.</h2>
                  <p class="cine-pillar__body" data-cine-pillar-body>
                    El fútbol es nuestra pasión y nuestro compromiso. Acompañamos a los jugadores más allá de su
                    etapa profesional.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Acto III: quiénes somos + CTAs textuales -->
        <div class="cine-exp__act cine-exp__act--outro" data-cine-act="outro">
          <div class="cine-glass">
            <div class="cine-glass__body cine-outro__panel">
              <p class="cine-outro__label" data-cine-outro-line>PH Sport</p>
              <p class="cine-outro__lead" data-cine-outro-line>
                Agencia de representación deportiva especializada en fútbol. Gestionamos carreras, negociamos
                contratos y acompañamos a los jugadores en cada etapa de su trayectoria.
              </p>
              <p class="cine-outro__ctas" data-cine-outro-line>
                <span class="cine-outro__cta">Conoce a nuestros jugadores</span>
                <span class="cine-outro__cta-sep" aria-hidden="true">·</span>
                <span class="cine-outro__cta">Quiénes somos</span>
              </p>
            </div>
          </div>
        </div>

        <p class="cine-exp__top-rest-msg" data-cine-top-rest-msg aria-hidden="true">
          Sigue deslizando · vuelve a recorrer la historia
        </p>

        <p class="cine-exp__hint">Desliza con calma · el logo te acompaña</p>
      </div>
    </div>
  </section>

  <script>
    import '@/scripts/logo3d-scroll-experiment';
  </script>
</BaseLayout>

<style>
  .cine-exp {
    --cine-glass-radius: 1rem;
    --cine-glass-max: min(24rem, 86vw);
    --cine-glass-pad-x: clamp(1.2rem, 3.2vw, 1.65rem);
    --cine-glass-pad-y: clamp(1.1rem, 3vw, 1.5rem);
    --cine-safe-x: clamp(1rem, 4vw, 2.75rem);
    position: relative;
    min-height: 750vh;
  }

  .cine-exp__track {
    position: relative;
    min-height: 750vh;
  }

  .cine-exp__sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
    background: #0a0e14;
    isolation: isolate;
  }

  .cine-exp__canvas {
    position: relative;
    z-index: 0;
    width: 100%;
    height: 100%;
  }

  .cine-exp__wash {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      radial-gradient(ellipse 88% 70% at 50% 44%, rgba(214, 178, 94, 0.06) 0%, transparent 55%),
      radial-gradient(ellipse 50% 40% at 82% 16%, rgba(255, 252, 245, 0.035) 0%, transparent 50%);
  }

  .cine-exp__vignette {
    position: absolute;
    inset: 0;
    z-index: 4;
    pointer-events: none;
    background: radial-gradient(ellipse 78% 72% at 50% 50%, transparent 42%, rgba(0, 0, 0, 0.38) 100%);
    opacity: 0.18;
  }

  .cine-exp__watermark {
    position: absolute;
    z-index: 1;
    left: 50%;
    top: 46%;
    transform: translate(-50%, -50%);
    font-family: var(--ph-font-display);
    font-weight: 900;
    font-size: clamp(8rem, 42vw, 22rem);
    line-height: 1;
    letter-spacing: -0.06em;
    color: rgba(255, 255, 255, 0.028);
    pointer-events: none;
    user-select: none;
  }

  .cine-exp__act {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: clamp(1rem, 4vw, 2.5rem);
  }

  /*
   * Carteles anclados al logo (JS: proyección 3D → posición absolute).
   * Sin esta clase (p. ej. reduced motion): layout flex de respaldo.
   */
  .cine-exp--anchored-panels .cine-exp__act {
    display: block;
    padding: 0;
  }

  /* Cristal base: misma huella en los tres actos */
  .cine-glass {
    position: relative;
    width: 100%;
    max-width: var(--cine-glass-max);
    padding: 1px;
    border-radius: var(--cine-glass-radius);
    background: linear-gradient(
      152deg,
      rgba(255, 255, 255, 0.2) 0%,
      rgba(255, 255, 255, 0.06) 45%,
      rgba(214, 178, 94, 0.14) 100%
    );
    box-shadow:
      0 16px 56px rgba(0, 0, 0, 0.4),
      inset 0 1px 0 rgba(255, 255, 255, 0.12);
  }

  .cine-glass::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(
      110deg,
      rgba(255, 255, 255, 0.1) 0%,
      transparent 40%,
      transparent 58%,
      rgba(214, 178, 94, 0.08) 100%
    );
    pointer-events: none;
  }

  .cine-glass__body {
    position: relative;
    border-radius: calc(var(--cine-glass-radius) - 1px);
    background: rgba(10, 14, 20, 0.42);
    backdrop-filter: blur(20px) saturate(150%);
    -webkit-backdrop-filter: blur(20px) saturate(150%);
    border: 1px solid rgba(255, 255, 255, 0.09);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  .cine-exp--anchored-panels .cine-glass {
    position: absolute;
    left: 0;
    top: 0;
    width: min(var(--cine-glass-max), calc(100vw - 2 * var(--cine-safe-x)));
    margin: 0;
    will-change: transform;
  }

  /* Intro: respaldo sin ancla (reduced / sin JS) */
  .cine-exp:not(.cine-exp--anchored-panels) .cine-exp__act--intro {
    align-items: flex-start;
    justify-content: flex-end;
    padding-bottom: clamp(4rem, 12vh, 6.5rem);
    padding-left: var(--cine-safe-x);
    padding-right: min(52vw, 17rem);
  }

  .cine-intro__panel {
    padding: var(--cine-glass-pad-y) var(--cine-glass-pad-x);
  }

  .cine-intro__tagline {
    margin: 0 0 1rem;
    font-family: var(--ph-font-display);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: var(--ph-gold);
    opacity: 0;
    transform: translate3d(0, 12px, 0);
  }

  .cine-intro__claim {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem 0.55rem;
    font-family: var(--ph-font-display);
    font-weight: 900;
    font-size: clamp(1.85rem, 6.5vw, 3.35rem);
    line-height: 1.05;
    letter-spacing: -0.032em;
    color: rgba(255, 255, 255, 0.96);
  }

  .cine-intro__word {
    display: inline-block;
    opacity: 0;
    transform: translate3d(0, 18px, 0);
  }

  .cine-exp:not(.cine-exp--anchored-panels) .cine-exp__act--pillars {
    align-items: flex-end;
    justify-content: flex-start;
    padding-top: clamp(1.75rem, 7vh, 3.5rem);
    padding-right: var(--cine-safe-x);
    padding-left: min(44vw, 15rem);
  }

  .cine-pillars__panel {
    padding: var(--cine-glass-pad-y) var(--cine-glass-pad-x);
  }

  .cine-pillars__eyebrow {
    margin: 0 0 1.15rem;
    font-family: var(--ph-font-display);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ph-gold-muted);
    opacity: 0;
    transform: translate3d(0, 10px, 0);
  }

  .cine-pillars__stack {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .cine-pillars__item {
    margin: 0;
    padding: 0.75rem 0;
    opacity: 0;
    transform: translate3d(0, 12px, 0);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .cine-pillars__item:first-of-type {
    border-top: none;
    padding-top: 0;
  }

  .cine-pillars__item:last-of-type {
    padding-bottom: 0;
  }

  .cine-pillar__title {
    margin: 0 0 0.45rem;
    font-family: var(--ph-font-display);
    font-size: 0.95rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    color: var(--ph-gold);
    opacity: 0;
    transform: translate3d(0, 8px, 0);
  }

  .cine-pillar__body {
    margin: 0;
    font-family: var(--ph-font-body);
    font-size: 0.82rem;
    line-height: 1.55;
    color: var(--ph-white-60);
    opacity: 0;
    transform: translate3d(0, 8px, 0);
  }

  .cine-exp:not(.cine-exp--anchored-panels) .cine-exp__act--outro {
    align-items: flex-start;
    justify-content: flex-start;
    padding-top: clamp(2rem, 8vh, 4.25rem);
    padding-left: var(--cine-safe-x);
    padding-right: min(48vw, 16rem);
    padding-bottom: clamp(2rem, 6vh, 3rem);
    text-align: left;
  }

  .cine-outro__panel {
    padding: var(--cine-glass-pad-y) var(--cine-glass-pad-x);
    text-align: left;
  }

  .cine-outro__label {
    margin: 0 0 0.85rem;
    font-family: var(--ph-font-display);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--ph-gold);
    opacity: 0;
    transform: translate3d(0, 14px, 0);
  }

  .cine-outro__lead {
    margin: 0 0 1.25rem;
    font-family: var(--ph-font-body);
    font-size: clamp(0.9rem, 2.2vw, 1.05rem);
    line-height: 1.62;
    color: rgba(255, 255, 255, 0.88);
    opacity: 0;
    transform: translate3d(0, 14px, 0);
  }

  .cine-outro__ctas {
    margin: 0;
    font-family: var(--ph-font-display);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
    opacity: 0;
    transform: translate3d(0, 12px, 0);
  }

  .cine-outro__cta-sep {
    margin: 0 0.4rem;
    color: var(--ph-gold-muted);
  }

  .cine-exp__top-rest-msg {
    position: absolute;
    z-index: 6;
    left: 50%;
    bottom: 4.25rem;
    transform: translateX(-50%);
    margin: 0;
    max-width: min(38ch, 90vw);
    text-align: center;
    font-family: var(--ph-font-display);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    line-height: 1.45;
    color: rgba(255, 255, 255, 0.48);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .cine-exp--top-rest .cine-exp__top-rest-msg {
    opacity: 1;
  }

  .cine-exp__hint {
    position: absolute;
    z-index: 6;
    left: 50%;
    bottom: 1.5rem;
    transform: translateX(-50%);
    margin: 0;
    font-family: var(--ph-font-display);
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.34);
    pointer-events: none;
    max-width: 90vw;
    text-align: center;
    transition: color 0.45s ease;
  }

  .cine-exp--top-rest .cine-exp__hint {
    color: rgba(255, 255, 255, 0.48);
  }

  .cine-exp.cine-exp--reduced .cine-exp__vignette {
    opacity: 0.36 !important;
  }

  .cine-exp.cine-exp--reduced .cine-exp__act--intro,
  .cine-exp.cine-exp--reduced .cine-exp__act--pillars {
    opacity: 0 !important;
    visibility: hidden !important;
  }

  .cine-exp.cine-exp--reduced .cine-exp__act--outro {
    opacity: 1 !important;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    justify-content: flex-end;
    padding: clamp(1rem, 4vw, 2.5rem);
    padding-bottom: clamp(3.5rem, 11vh, 6rem);
    text-align: right;
  }

  .cine-exp.cine-exp--reduced .cine-exp__act--outro .cine-glass {
    position: relative;
    left: auto !important;
    top: auto !important;
    transform: none !important;
    width: 100%;
  }

  .cine-exp.cine-exp--reduced .cine-outro__panel {
    text-align: right;
  }

  .cine-exp.cine-exp--reduced [data-cine-outro-line] {
    opacity: 1 !important;
    transform: none !important;
  }

  @media (max-width: 768px) {
    .cine-exp {
      min-height: 700vh;
    }

    .cine-exp__track {
      min-height: 700vh;
    }

    .cine-exp:not(.cine-exp--anchored-panels) .cine-exp__act--intro {
      padding-right: min(28vw, 1.25rem);
    }

    .cine-exp:not(.cine-exp--anchored-panels) .cine-exp__act--pillars {
      padding-left: min(34vw, 1.5rem);
    }

    .cine-exp:not(.cine-exp--anchored-panels) .cine-exp__act--outro {
      padding-right: min(32vw, 1.25rem);
    }

    .cine-exp__hint {
      bottom: calc(1rem + env(safe-area-inset-bottom, 0px));
      font-size: 0.56rem;
    }
  }
</style>

<style is:global>
  html:has([data-cine-exp]) .bg-logo-parallax {
    opacity: 0;
    visibility: hidden;
  }
</style>
